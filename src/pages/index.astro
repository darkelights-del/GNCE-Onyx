---
/**
 * Home — a clean type-first lander. The same four blocks the WebGL
 * journey carried (who we are, lineage, robot, team), laid out as
 * scroll sections with one motion trick each: split hero headline,
 * count-up squad numbers, diagonal-wipe robot panel, staggered roster
 * rows, and a magnetic close.
 *
 * The WebGL ONYX journey this replaced is parked, fully working, at
 * /lab/onyx/ (src/pages/lab/onyx.astro). It is unlinked on purpose.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import Reveal from '../components/Reveal.astro';

const base = import.meta.env.BASE_URL.replace(/\/+$/, '');

const numbers = ['22489', '26112', '26413', '26111'];
const roster = [
  'Ethan Zhang',
  'Ethan Zhuang',
  'Anson Su',
  'Adrian Chang',
  'Leo Li',
  'Nicholas Colli',
  'Raymond Liu',
];
---

<BaseLayout
  title="Home"
  description="GNCE Onyx is a rookie FIRST Tech Challenge team at Weston High School, built by championship veterans, competing in the 2026-2027 BIOBUZZ season."
>
  <!-- HERO: type is the imagery. -->
  <section class="hero" aria-label="GNCE Onyx">
    <div class="mx-auto w-full max-w-5xl px-5 sm:px-8">
      <p class="type-label text-muted">First Tech Challenge · Weston, MA</p>
      <p class="hero-script type-script mt-6">GNCE Onyx</p>
      <h1 class="hero-title type-display mt-4" data-split>A rookie team of championship veterans.</h1>
      <Reveal variant="up" class="mt-8 max-w-prose">
        <p class="text-muted">Built for the 2026-2027 BIOBUZZ season, presented by RTX.</p>
      </Reveal>
      <Reveal variant="up" delay={90} class="mt-10">
        <p class="hero-cta">
          <a href={`${base}/contact/`} class="btn btn-solid" data-magnetic="0.4">Sponsor the team</a>
          <a href={`${base}/season/`} class="hero-link">Our first season</a>
        </p>
      </Reveal>
    </div>
  </section>

  <!-- LINEAGE: the proof counts itself up. -->
  <section class="mx-auto max-w-5xl px-5 py-24 sm:px-8 sm:py-32">
    <h2 class="type-display text-[clamp(1.75rem,4vw,3rem)]" data-split>Four of our seven are GNCE veterans.</h2>
    <Reveal variant="up" class="mt-6 max-w-prose">
      <p class="text-muted">World championship and international records behind them. Their squad numbers:</p>
    </Reveal>
    <div class="mt-14 grid grid-cols-2 gap-x-6 gap-y-10 sm:grid-cols-4" data-reveal-group>
      {
        numbers.map((n) => (
          <Reveal variant="up">
            <p class="stat-num hairline border-t pt-4" data-count={n}>
              {n}
            </p>
          </Reveal>
        ))
      }
    </div>
  </section>

  <!-- ROBOT: specs land as one diagonal wipe. -->
  <section class="mx-auto max-w-5xl px-5 py-24 sm:px-8 sm:py-32">
    <h2 class="type-display max-w-[22ch] text-[clamp(1.75rem,4vw,3rem)]" data-split>
      Designs we can fix in the pit and trust on the field.
    </h2>
    <Reveal variant="up" class="mt-6 max-w-prose">
      <p class="text-muted">Proven where it counts. The build starts at kickoff.</p>
    </Reveal>
    <Reveal variant="diag" class="mt-12">
      <div class="glass flex flex-wrap items-baseline gap-x-12 gap-y-4 p-6 sm:p-8">
        <p class="text-sm">Size <span class="stub" title="Set at kickoff">TBD</span></p>
        <p class="text-sm">Weight <span class="stub" title="Set at kickoff">TBD</span></p>
        <p class="text-sm">Drivetrain <span class="stub" title="Set at kickoff">TBD</span></p>
      </div>
    </Reveal>
  </section>

  <!-- TEAM: seven names, wiping in from alternating sides. -->
  <section class="mx-auto max-w-5xl px-5 py-24 sm:px-8 sm:py-32">
    <h2 class="type-display text-[clamp(1.75rem,4vw,3rem)]" data-split>Our team</h2>
    <ul class="mt-12" data-reveal-group>
      {
        roster.map((name, i) => (
          <li>
            <Reveal variant={i % 2 ? 'left' : 'right'} class="hairline border-t">
              <p class="roster-name py-4">{name}</p>
            </Reveal>
          </li>
        ))
      }
    </ul>
    <Reveal variant="up" class="mt-8">
      <p class="text-muted">Two or three more, joining soon.</p>
    </Reveal>
  </section>

  <!-- CLOSE -->
  <section class="mx-auto max-w-5xl px-5 pb-36 pt-10 sm:px-8">
    <div class="hairline border-t pt-16">
      <h2 class="type-display text-[clamp(2.25rem,7vw,5rem)]" data-split>Back the build.</h2>
      <Reveal variant="up" class="mt-10">
        <p>
          <a href={`${base}/contact/`} class="btn btn-solid" data-magnetic="0.4">Sponsor the team</a>
        </p>
      </Reveal>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    display: flex;
    align-items: center;
    min-height: 100svh;
    padding: 6rem 0 4rem;
  }

  .hero-script {
    font-size: clamp(2.5rem, 6vw, 3.6rem);
    color: var(--color-accent);
    line-height: 0.9;
  }

  .hero-title {
    font-size: clamp(2.25rem, 5.5vw, 4.25rem);
    line-height: 1.03;
    max-width: 24ch;
  }

  .hero-cta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1.5rem;
  }

  .hero-link {
    color: var(--color-ink);
    font-weight: 700;
    font-size: 0.9375rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-decoration: underline;
    text-underline-offset: 0.35em;
    text-decoration-color: var(--color-accent);
  }

  /* Squad numbers: the body serif with fixed-width digits, so the
     count-up never jitters the layout. */
  .stat-num {
    font-family: var(--font-text);
    font-weight: 700;
    font-size: clamp(1.6rem, 3.4vw, 2.4rem);
    line-height: 1;
    font-variant-numeric: tabular-nums lining-nums;
  }

  /* Roster: the cleaner body serif, not the distressed display face, so
     seven names read cleanly at a glance. */
  .roster-name {
    font-family: var(--font-text);
    font-weight: 700;
    font-size: clamp(1.4rem, 3vw, 2rem);
    line-height: 1.2;
  }
</style>
