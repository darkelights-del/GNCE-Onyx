---
/**
 * Home — one immersive journey. The ONYX wordmark is a 3D object; the
 * camera flies from the whole word into each letter (O -> N -> Y -> X),
 * and each letter frames a segment of content (motion.ts, initJourney).
 * Without JS / under reduced motion it degrades to a stacked static page.
 */
import BaseLayout from '../layouts/BaseLayout.astro';

const base = import.meta.env.BASE_URL.replace(/\/+$/, '');

const stations = [
  { letter: 'O', key: 'onyx' },
  { letter: 'N', key: 'roots' },
  { letter: 'Y', key: 'robot' },
  { letter: 'X', key: 'crew' },
];

const numbers = ['22489', '26112', '26413', '26111'];
const roster = ['Ethan Zhang', 'Ethan Zhuang', 'Anson Su', 'Adrian Chang', 'Leo Li', 'Nicholas Colli', 'Raymond Liu'];
const specs = ['Size', 'Mass', 'Drivetrain', 'TeleOp', 'Auto', 'Solo score'];
---

<BaseLayout
  title="Home"
  description="GNCE Onyx is a rookie FIRST Tech Challenge team at Weston High School, built by championship veterans, competing in the 2026-2027 BIOBUZZ season."
>
  <section class="journey" data-journey aria-label="GNCE Onyx">
    <div class="journey-stage scene-3d">
      <!-- 3D wordmark: the camera flies through these letters -->
      <div class="journey-world preserve-3d" data-world aria-hidden="true">
        {
          stations.map((s) => (
            <div class="station-letter preserve-3d">
              {Array.from({ length: 8 }).map((_, d) => (
                <span
                  class="letter-face"
                  style={`transform:translateZ(${-(d + 1) * 4}px);color:color-mix(in srgb, var(--color-surface) ${92 - d * 9}%, var(--color-bg))`}
                >
                  {s.letter}
                </span>
              ))}
              <span class="letter-front">{s.letter}</span>
            </div>
          ))
        }
      </div>

      <!-- Content, synced to each letter -->
      <div class="journey-overlay">
        <!-- O: identity -->
        <div class="panel" data-panel="0">
          <p class="type-label text-muted">FIRST Tech Challenge · Weston, MA</p>
          <p class="type-script panel-script">GNCE Onyx</p>
          <p class="panel-sub">
            A rookie robotics team of championship veterans, built for the
            2026-2027 BIOBUZZ season.
          </p>
          <p class="panel-cta">
            <a href={`${base}/contact/`} class="btn btn-solid" data-magnetic="0.4">Sponsor the team</a>
            <a href={`${base}/season/`} class="panel-link">Our first season</a>
          </p>
        </div>

        <!-- N: roots (brief, not highlighted) -->
        <div class="panel" data-panel="1">
          <h2 class="type-display panel-head">Where we come from</h2>
          <p class="panel-sub">
            Four of our seven are veterans of four GNCE teams, with world
            championship and international records.
          </p>
          <p class="panel-numbers type-label text-muted">{numbers.join('  ·  ')}</p>
        </div>

        <!-- Y: our robot -->
        <div class="panel" data-panel="2">
          <h2 class="type-display panel-head">Our robot</h2>
          <p class="panel-sub">
            Proven designs we can fix in the pit and trust on the field. The
            build starts at kickoff.
          </p>
          <ul class="panel-specs">
            {specs.map((s) => <li><span class="text-muted">{s}</span><span class="stub" title="Set at kickoff">TBD</span></li>)}
          </ul>
        </div>

        <!-- X: crew + close -->
        <div class="panel" data-panel="3">
          <h2 class="type-display panel-head">The crew</h2>
          <p class="panel-roster">{roster.join(' · ')}. Two or three more, joining soon.</p>
          <p class="panel-cta">
            <a href={`${base}/contact/`} class="btn btn-solid" data-magnetic="0.4">Back the build</a>
          </p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .journey {
    position: relative;
  }

  .journey-stage {
    position: relative;
    height: 100svh;
    overflow: clip;
    perspective: 1200px;
  }

  .journey-world {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.12em;
    transform-origin: 0 0;
    font-family: var(--font-display);
    font-size: clamp(5rem, 20vw, 16rem);
    line-height: 1;
    will-change: transform;
  }

  .station-letter {
    position: relative;
    display: inline-block;
  }

  /* Front face: a bright outline that reads as a wordmark. */
  .letter-front {
    position: relative;
    z-index: 2;
    color: transparent;
    -webkit-text-stroke: 1.5px color-mix(in srgb, var(--color-ink) 78%, transparent);
  }

  /* Extrusion body: solid dark purple steps behind the outline. */
  .letter-face {
    position: absolute;
    top: 0;
    left: 0;
  }

  /* Content overlay (screen space, crisp) */
  .journey-overlay {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .panel {
    position: absolute;
    left: clamp(1.25rem, 6vw, 6rem);
    bottom: clamp(3rem, 12vh, 8rem);
    width: min(90vw, 34rem);
    pointer-events: auto;
  }

  .panel > * + * {
    margin-top: 1.25rem;
  }

  .panel-head {
    font-size: clamp(2rem, 5vw, 3.5rem);
    line-height: 1;
  }

  .panel-script {
    font-size: clamp(1.75rem, 5vw, 3rem);
    color: var(--color-accent);
  }

  .panel-sub {
    max-width: 32rem;
    color: var(--color-muted);
  }

  .panel-cta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1.5rem;
  }

  .panel-link {
    color: var(--color-ink);
    font-weight: 700;
    font-size: 0.9375rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-decoration: underline;
    text-underline-offset: 0.35em;
    text-decoration-color: var(--color-accent);
  }

  .panel-numbers {
    letter-spacing: 0.18em;
  }

  .panel-specs {
    columns: 2;
    column-gap: 2.5rem;
    max-width: 30rem;
  }

  .panel-specs li {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    border-top: 1px solid var(--color-line);
    padding: 0.5rem 0;
    break-inside: avoid;
  }

  .panel-roster {
    max-width: 34rem;
    color: var(--color-ink);
    line-height: 1.6;
  }

  /* ---- No-JS / reduced motion: a readable stacked page ---------- */
  :global(html:not(.gsap)) .journey-stage {
    height: auto;
    overflow: visible;
    perspective: none;
  }

  :global(html:not(.gsap)) .journey-world {
    position: relative;
    inset: auto;
    flex-wrap: wrap;
    font-size: clamp(4rem, 16vw, 10rem);
    padding: 8rem 1.25rem 2rem;
    transform: none !important;
  }

  :global(html:not(.gsap)) .journey-overlay {
    position: static;
  }

  :global(html:not(.gsap)) .panel {
    position: static;
    width: auto;
    max-width: 42rem;
    padding: 3rem clamp(1.25rem, 6vw, 6rem);
  }
</style>
