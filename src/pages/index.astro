---
/**
 * Home — one continuous cinematic take. The ONYX word is a big, crisp 3D
 * object that the camera tracks across left to right; as each letter fills
 * the frame, its content is born from inside the letter and runs around it
 * (motion.ts, initJourney). The word is the vehicle; the words are the point.
 * Without JS / under reduced motion it degrades to a stacked static page.
 */
import BaseLayout from '../layouts/BaseLayout.astro';

const base = import.meta.env.BASE_URL.replace(/\/+$/, '');

const letters = ['O', 'N', 'Y', 'X'];
const numbers = ['22489', '26112', '26413', '26111'];
const roster = 'Ethan Zhang · Ethan Zhuang · Anson Su · Adrian Chang · Leo Li · Nicholas Colli · Raymond Liu';
---

<BaseLayout
  title="Home"
  description="GNCE Onyx is a rookie FIRST Tech Challenge team at Weston High School, built by championship veterans, competing in the 2026-2027 BIOBUZZ season."
>
  <section class="journey" data-journey aria-label="GNCE Onyx">
    <div class="journey-stage scene-3d">
      <!-- 3D wordmark: rendered large, the camera only ever scales it down -->
      <div class="journey-world preserve-3d" data-world aria-hidden="true">
        {
          letters.map((letter) => (
            <div class="station-letter preserve-3d">
              {Array.from({ length: 8 }).map((_, d) => (
                <span
                  class="letter-face"
                  style={`transform:translateZ(${-(d + 1) * 5}px);color:color-mix(in srgb, var(--color-surface) ${94 - d * 9}%, var(--color-bg))`}
                >
                  {letter}
                </span>
              ))}
              <span class="letter-front">{letter}</span>
            </div>
          ))
        }
      </div>

      <!-- Content, born from each letter as the camera arrives -->
      <div class="journey-overlay">
        <!-- O: who we are -->
        <div class="flow" data-flow="0">
          <div class="flow-inner">
            <p class="flow-line flow-eyebrow type-label text-muted">First Tech Challenge · Weston, MA</p>
            <p class="flow-line flow-script type-script">GNCE Onyx</p>
            <h1 class="flow-line flow-hero type-display">A rookie team of championship veterans.</h1>
            <p class="flow-line flow-support">Built for the 2026-2027 BIOBUZZ season, presented by RTX.</p>
            <p class="flow-line flow-cta">
              <a href={`${base}/contact/`} class="btn btn-solid" data-magnetic="0.4">Sponsor the team</a>
              <a href={`${base}/season/`} class="flow-link">Our first season</a>
            </p>
          </div>
        </div>

        <!-- N: where we come from -->
        <div class="flow flow-right" data-flow="1">
          <div class="flow-inner">
            <p class="flow-line flow-eyebrow type-label text-muted">Where we come from</p>
            <h2 class="flow-line flow-hero type-display">Four of our seven are GNCE veterans.</h2>
            <p class="flow-line flow-support">World championship and international records behind them.</p>
            <p class="flow-line flow-meta type-label text-muted">{numbers.join('  ·  ')}</p>
          </div>
        </div>

        <!-- Y: our robot -->
        <div class="flow" data-flow="2">
          <div class="flow-inner">
            <p class="flow-line flow-eyebrow type-label text-muted">Our robot</p>
            <h2 class="flow-line flow-hero type-display">Designs we can fix in the pit and trust on the field.</h2>
            <p class="flow-line flow-support">Proven where it counts. The build starts at kickoff.</p>
            <p class="flow-line flow-meta type-label text-muted">Size, weight, drivetrain <span class="stub" title="Set at kickoff">TBD</span></p>
          </div>
        </div>

        <!-- X: the crew + close -->
        <div class="flow flow-right" data-flow="3">
          <div class="flow-inner">
            <p class="flow-line flow-eyebrow type-label text-muted">The crew</p>
            <h2 class="flow-line flow-hero type-display flow-hero-sm">{roster}</h2>
            <p class="flow-line flow-support">Two or three more, joining soon.</p>
            <p class="flow-line flow-cta">
              <a href={`${base}/contact/`} class="btn btn-solid" data-magnetic="0.4">Back the build</a>
            </p>
          </div>
        </div>
      </div>

      <!-- Scroll cue, fades once you move -->
      <p class="journey-cue type-label text-muted" data-journey-cue>Scroll</p>
    </div>
  </section>
</BaseLayout>

<style>
  .journey {
    position: relative;
  }

  .journey-stage {
    position: relative;
    height: 100svh;
    overflow: clip;
    perspective: 1400px;
  }

  /* The word lives at natural (large) size; the camera scales it DOWN to the
     overview and up to at most 1:1 on a letter, so text never upscales. */
  .journey-world {
    position: absolute;
    top: 0;
    left: 0;
    width: max-content;
    display: flex;
    align-items: center;
    gap: 0.1em;
    transform-origin: 0 0;
    font-family: var(--font-display);
    font-size: 132vh;
    line-height: 1;
  }

  .station-letter {
    position: relative;
    display: inline-block;
    will-change: transform;
    backface-visibility: hidden;
  }

  /* Front face: a quiet outline. The letter frames the words; it never
     competes with them, so it reads as a vehicle, not the headline. */
  .letter-front {
    position: relative;
    z-index: 2;
    color: transparent;
    -webkit-text-stroke: 0.006em color-mix(in srgb, var(--color-ink) 50%, transparent);
  }

  /* Extrusion body: solid dark steps that read as a tunnel the words rise out of. */
  .letter-face {
    position: absolute;
    top: 0;
    left: 0;
  }

  /* Content overlay — screen space, always crisp, centered on the framed letter. */
  .journey-overlay {
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;
    pointer-events: none;
  }

  .flow {
    grid-area: 1 / 1;
    width: min(88vw, 44rem);
    pointer-events: none;
  }

  /* Nudge some blocks off dead-center so they sit in the letter's open space. */
  .flow-right {
    justify-self: end;
    width: min(80vw, 40rem);
  }

  .flow-inner {
    display: flex;
    flex-direction: column;
    gap: clamp(0.7rem, 1.7vw, 1.2rem);
  }

  .flow-line {
    will-change: transform, clip-path;
  }

  .flow-eyebrow {
    margin-bottom: 0.2rem;
  }

  .flow-script {
    font-size: clamp(2rem, 6vw, 3.6rem);
    color: var(--color-accent);
    line-height: 0.9;
  }

  .flow-hero {
    font-size: clamp(2.1rem, 5.2vw, 3.9rem);
    line-height: 1.03;
    max-width: 18ch;
  }

  .flow-hero-sm {
    font-size: clamp(1.4rem, 3vw, 2.1rem);
    line-height: 1.25;
    max-width: 26ch;
  }

  .flow-support {
    max-width: 34ch;
    color: var(--color-muted);
    font-size: 1.0625rem;
  }

  .flow-meta {
    letter-spacing: 0.16em;
  }

  .flow-cta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1.5rem;
    pointer-events: auto;
    margin-top: 0.6rem;
  }

  .flow-link {
    color: var(--color-ink);
    font-weight: 700;
    font-size: 0.9375rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-decoration: underline;
    text-underline-offset: 0.35em;
    text-decoration-color: var(--color-accent);
  }

  .journey-cue {
    position: absolute;
    left: 50%;
    bottom: clamp(1.5rem, 4vh, 2.5rem);
    transform: translateX(-50%);
    pointer-events: none;
  }

  .journey-cue::after {
    content: '';
    display: block;
    width: 1px;
    height: 2.2rem;
    margin: 0.6rem auto 0;
    background: var(--color-line);
  }

  /* ---- No-JS / reduced motion: a readable stacked page ---------- */
  :global(html:not(.gsap)) .journey-stage {
    height: auto;
    overflow: visible;
    perspective: none;
  }

  :global(html:not(.gsap)) .journey-world {
    position: relative;
    width: auto;
    flex-wrap: wrap;
    justify-content: center;
    font-size: clamp(4rem, 16vw, 10rem);
    padding: 8rem 1.25rem 2rem;
    transform: none !important;
  }

  :global(html:not(.gsap)) .journey-overlay {
    position: static;
    display: block;
  }

  :global(html:not(.gsap)) .flow {
    width: auto;
    max-width: 44rem;
    margin: 0 auto;
    padding: 3rem clamp(1.25rem, 6vw, 6rem);
  }

  :global(html:not(.gsap)) .flow-right {
    justify-self: auto;
  }

  :global(html:not(.gsap)) .journey-cue {
    display: none;
  }
</style>
