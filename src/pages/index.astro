---
/**
 * Home — the forge story.
 * Act 1: pinned scroll scene. Four team numbers converge and "Four
 * teams." gives way to "One Onyx." struck in ember. A single custom
 * property --p (0..1), set by JS on .forge-track, drives every value
 * through calc(), so it works in every browser and degrades to a clean
 * static hero without JS or under reduced motion.
 * Then: lineage ledger → mission → robot → roster → sponsor band.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import Placeholder from '../components/Placeholder.astro';
import Reveal from '../components/Reveal.astro';
import SectionLabel from '../components/SectionLabel.astro';

const base = import.meta.env.BASE_URL.replace(/\/+$/, '');

/** The four squads whose veterans formed Onyx; scatter offsets feed the
 *  converge animation. */
const lineage = [
  {
    num: '22489',
    name: 'GNCE Diamond',
    sx: '-30vw',
    sy: '-24vh',
    honors: [
      '2025 States: Winning Alliance Captain',
      '2025 FIRST World Championship, Jemison Division: Motivate Award 2nd Place',
      '2025 MTI: Hardware Honorable Mention',
      '2026 States: Innovate Award',
      '2026 Michiana, Croft Division: Finalist Alliance, Control Award 1st Place',
      '2026 MTI: Mechatronics Synergy Winner',
    ],
  },
  {
    num: '26112',
    name: 'GNCE Organized Anarchy',
    sx: '28vw',
    sy: '-20vh',
    honors: [
      '2025 States: Finalist Alliance Captain',
      '2025 New England Premier Event, Courville Division',
      '2026 States: Finalist Alliance Captain',
      '2026 FIRST World Championship, Jackson Division: Playoff Semifinalist',
      '2026 Multinational Tech Invitational qualification',
    ],
  },
  { num: '26413', name: 'GNCE Mercury', sx: '-26vw', sy: '22vh', honors: [] },
  { num: '26111', name: 'GNCE Electrified Chickens', sx: '30vw', sy: '24vh', honors: [] },
];

const roster = [
  { name: 'Ethan Zhang', role: 'Captain' },
  { name: 'Ethan Zhuang', role: 'Captain' },
  { name: 'Anson Su', role: '' },
  { name: 'Adrian Chang', role: '' },
  { name: 'Leo Li', role: '' },
  { name: 'Nicholas Colli', role: '' },
  { name: 'Raymond Liu', role: '' },
];

const specs = [
  { key: 'Size', value: 'TBD' },
  { key: 'Mass', value: 'TBD' },
  { key: 'Drivetrain', value: 'TBD' },
  { key: 'TeleOp', value: 'TBD' },
  { key: 'Auto', value: 'TBD' },
  { key: 'Solo score', value: 'TBD' },
];
---

<BaseLayout
  title="Home"
  description="GNCE Onyx is a rookie FIRST Tech Challenge team at Weston High School, built by veterans of four GNCE teams for the 2026-2027 BIOBUZZ season."
>
  <!-- ============================================= ACT 1: THE FORGE -->
  <section class="forge-track" aria-label="GNCE Onyx: four teams forged into one">
    <div class="forge-stage ember">
      <p class="fs-eyebrow type-label">
        FIRST Tech Challenge · Weston High School
      </p>

      <div class="fs-numbers" aria-hidden="true">
        {
          lineage.map((team) => (
            <span class="fs-number type-label" style={`--sx:${team.sx};--sy:${team.sy}`}>
              {team.num}
            </span>
          ))
        }
      </div>

      <div class="fs-heads">
        <p class="fs-head-a type-display" aria-hidden="true">Four teams.</p>
        <h1 class="fs-head-b type-display">One Onyx.</h1>
      </div>

      <div class="fs-tail">
        <p class="fs-sub">
          A rookie FTC team at Weston High, built by members of four GNCE
          teams, competing in BIOBUZZ 2026-2027.
        </p>
        <p class="fs-cta">
          <a href={`${base}/contact/`} class="btn btn-solid">Sponsor the team</a>
          <a href={`${base}/season/`} class="fs-link">See our first season</a>
        </p>
      </div>
    </div>
  </section>

  <!-- ================================================ LINEAGE LEDGER -->
  <section class="bg-surface py-28 sm:py-36">
    <div class="mx-auto max-w-5xl px-5 sm:px-8">
      <Reveal variant="clip">
        <h2 class="type-display text-[clamp(2.25rem,6vw,4.5rem)]">
          Where we come from
        </h2>
      </Reveal>

      <Reveal variant="up" delay={100} class="mt-6 max-w-2xl">
        <p class="text-muted">
          Four of our seven members are returning veterans from four GNCE
          teams. Their record travels with them.
        </p>
      </Reveal>

      <div class="mt-16" data-reveal-group>
        {
          lineage.map((team) => (
            <Reveal class="hairline border-t py-8 first:border-t-0 sm:py-10">
              <div class="grid gap-4 sm:grid-cols-[8rem_1fr]">
                <p class="type-label text-2xl text-accent">{team.num}</p>
                <div>
                  <h3 class="type-display text-[clamp(1.5rem,3vw,2.25rem)]">{team.name}</h3>
                  {team.honors.length > 0 && (
                    <ul class="mt-4 max-w-2xl">
                      {team.honors.map((honor) => (
                        <li class="hairline border-t py-2 text-[0.9375rem] text-muted first:border-t-0">
                          {honor}
                        </li>
                      ))}
                    </ul>
                  )}
                </div>
              </div>
            </Reveal>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ======================================================== MISSION -->
  <section class="py-32 sm:py-44">
    <div class="mx-auto max-w-5xl px-5 sm:px-8">
      <Reveal variant="clip">
        <p class="type-display max-w-4xl text-[clamp(1.875rem,4.5vw,3.5rem)]">
          Consistent, reliable robots we can maintain and trust on the field.
        </p>
      </Reveal>
      <Reveal variant="up" delay={120} class="mt-8 max-w-2xl">
        <p class="text-muted">
          GNCE Onyx favors proven designs over complex ones with more ways to
          fail: machines we understand end to end, fix in the pit, and count
          on in a match. Off the field, we run outreach to get younger
          students into robotics and grow FIRST and STEM in and around
          Weston, Massachusetts.
        </p>
      </Reveal>
    </div>
  </section>

  <!-- ====================================================== THE ROBOT -->
  <section class="bg-surface py-24 sm:py-32">
    <div class="mx-auto max-w-5xl px-5 sm:px-8">
      <SectionLabel title="The robot" class="mb-12" />

      <div class="grid gap-10 md:grid-cols-2">
        <Reveal variant="left">
          <Placeholder name="home-robot-photo">
            <div class="slot aspect-[4/3]">
              <span class="type-label text-muted">Robot photo, coming at kickoff</span>
            </div>
          </Placeholder>
        </Reveal>

        <Reveal variant="right" delay={120}>
          <div class="flex h-full flex-col">
            <p class="max-w-prose text-muted">
              The BIOBUZZ build starts at kickoff. This space follows the
              machine from first sketch to competition-ready.
            </p>
            <Placeholder name="home-robot-specs" class="mt-8 px-5 py-4">
              <dl>
                {
                  specs.map((spec) => (
                    <div class="hairline flex items-baseline justify-between gap-6 border-b py-3 last:border-b-0">
                      <dt class="type-label text-muted">{spec.key}</dt>
                      <dd class="text-[0.9375rem]">{spec.value}</dd>
                    </div>
                  ))
                }
              </dl>
            </Placeholder>
          </div>
        </Reveal>
      </div>
    </div>
  </section>

  <!-- ========================================================= ROSTER -->
  <section class="py-28 sm:py-36">
    <div class="mx-auto max-w-5xl px-5 sm:px-8">
      <SectionLabel title="Roster" class="mb-12" />

      <Reveal variant="up">
        <p class="max-w-2xl text-lg text-muted">
          Seven members and counting, led by two captains. Four of us
          competed at Worlds and international invitationals on our previous
          teams.
        </p>
      </Reveal>

      <ol class="mt-12 grid gap-x-12 sm:grid-cols-2" data-reveal-group>
        {
          roster.map((member) => (
            <Reveal
              as="li"
              class="hairline flex items-baseline justify-between gap-6 border-b py-4"
            >
              <span class="type-display text-[1.625rem]">{member.name}</span>
              {member.role && <span class="type-label text-accent">{member.role}</span>}
            </Reveal>
          ))
        }
        <Reveal as="li" class="flex items-baseline py-4">
          <span class="text-muted italic">Two or three more joining soon.</span>
        </Reveal>
      </ol>
    </div>
  </section>

  <!-- ==================================================== SPONSOR BAND -->
  <section class="ember bg-surface py-32 sm:py-44">
    <div class="mx-auto max-w-5xl px-5 sm:px-8">
      <Reveal variant="clip">
        <h2 class="type-display max-w-4xl text-[clamp(2.75rem,8vw,6.5rem)]">
          Back the build
        </h2>
      </Reveal>

      <Reveal variant="up" delay={120} class="mt-8 max-w-2xl">
        <p class="text-muted">
          Sponsorship covers what a season actually costs: parts, tools,
          registration, and travel. Cash is one way in. Mentorship, shop
          tours, and co-hosted STEM events for Weston students count just as
          much.
        </p>
      </Reveal>

      <Reveal variant="up" delay={200} class="mt-10">
        <a href={`${base}/contact/`} class="btn btn-solid">Sponsor the team</a>
      </Reveal>
    </div>
  </section>
</BaseLayout>

<style>
  /* ---- Act 1: The Forge scene ------------------------------------ */
  /* One scrubbed scene driven by a single custom property --p (0..1)
     set by JS on .forge-track. Every animated value is a calc() of --p,
     so it works in every browser and never leaves the two headlines
     both visible. Without JS or under reduced motion the static
     composition below applies instead. */
  .forge-stage {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: center;
    gap: 1.5rem;
    min-height: 100svh;
    padding: clamp(1.25rem, 5vw, 5rem);
    background: var(--color-bg);
    overflow: clip;
  }

  .fs-eyebrow {
    color: var(--color-muted);
  }

  .fs-numbers {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .fs-number {
    position: absolute;
    top: 50%;
    left: 50%;
    font-size: clamp(1rem, 2.2vw, 1.5rem);
    color: var(--color-muted);
    opacity: 0.4;
    transform: translate(-50%, -50%) translate(var(--sx), var(--sy));
  }

  .fs-heads {
    display: grid;
  }

  .fs-head-a,
  .fs-head-b {
    grid-area: 1 / 1;
    font-size: clamp(3.25rem, 12vw, 10rem);
  }

  .fs-head-b {
    color: var(--color-accent);
  }

  .fs-sub {
    max-width: 34rem;
    color: var(--color-muted);
  }

  .fs-cta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1.5rem;
    margin-top: 1.5rem;
  }

  .fs-link {
    color: var(--color-ink);
    font-family: var(--font-label);
    font-size: 0.9375rem;
    text-decoration: underline;
    text-underline-offset: 0.35em;
    text-decoration-color: var(--color-accent);
    transition: color 200ms ease;
  }

  @media (hover: hover) and (pointer: fine) {
    .fs-link:hover {
      color: var(--color-accent);
    }
  }

  /* ---- Static composition (no JS, reduced motion, before scrub) --- */
  .fs-head-a {
    display: none;
  }

  /* Gentle load entrance for the static hero; suppressed once the JS
     scrub takes over (.forge-track.is-scrub). */
  :global(html.js) .forge-track:not(.is-scrub) .fs-head-b,
  :global(html.js) .forge-track:not(.is-scrub) .fs-tail,
  :global(html.js) .forge-track:not(.is-scrub) .fs-eyebrow {
    animation: fs-arrive 640ms var(--ease-out-strong) both;
  }

  :global(html.js) .forge-track:not(.is-scrub) .fs-head-b {
    animation-delay: 80ms;
  }

  :global(html.js) .forge-track:not(.is-scrub) .fs-tail {
    animation-delay: 220ms;
  }

  @keyframes fs-arrive {
    from {
      opacity: 0;
      transform: translateY(22px);
    }
  }

  /* ---- The scrub (JS sets --p; pure calc, all browsers) ---------- */
  .forge-track.is-scrub {
    height: 320svh;
  }

  .forge-track.is-scrub .forge-stage {
    position: sticky;
    top: 0;
    height: 100svh;
  }

  /* Four numbers slide to center (p:0 -> 0.4) then fade (~0.45). */
  .forge-track.is-scrub .fs-number {
    --conv: min(calc(var(--p) / 0.4), 1);
    opacity: calc(0.55 * (1 - clamp(0, calc((var(--p) - 0.38) * 12), 1)));
    transform: translate(-50%, -50%)
      translate(
        calc(var(--sx) * (1 - var(--conv))),
        calc(var(--sy) * (1 - var(--conv)))
      );
  }

  /* "Four teams." holds, then yields (0.30 -> 0.44). */
  .forge-track.is-scrub .fs-head-a {
    --out: clamp(0, calc((var(--p) - 0.30) * 7), 1);
    display: block;
    opacity: calc(1 - var(--out));
    transform: translateY(calc(var(--out) * -14px));
  }

  /* "One Onyx." strikes in (0.42 -> 0.58). */
  .forge-track.is-scrub .fs-head-b {
    --in: clamp(0, calc((var(--p) - 0.42) * 6), 1);
    opacity: var(--in);
    transform: scale(calc(0.94 + var(--in) * 0.06));
  }

  /* Sub + CTA settle last (0.66 -> 0.82). */
  .forge-track.is-scrub .fs-tail {
    --in: clamp(0, calc((var(--p) - 0.66) * 6), 1);
    opacity: var(--in);
    transform: translateY(calc((1 - var(--in)) * 18px));
  }
</style>

<script>
  // Deterministic scrub: map scroll progress through the pinned track to
  // --p in [0,1]. No scroll-timeline dependency, no Astro-scoping traps.
  function initForge() {
    const track = document.querySelector<HTMLElement>('.forge-track');
    if (!track) return;
    if (matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    track.classList.add('is-scrub');
    let queued = false;
    const update = () => {
      queued = false;
      const total = track.offsetHeight - window.innerHeight;
      const p = total > 0 ? Math.min(Math.max(-track.getBoundingClientRect().top / total, 0), 1) : 0;
      track.style.setProperty('--p', p.toFixed(4));
    };
    addEventListener(
      'scroll',
      () => {
        if (!queued) {
          queued = true;
          requestAnimationFrame(update);
        }
      },
      { passive: true }
    );
    addEventListener('resize', update, { passive: true });
    update();
  }

  initForge();
</script>
