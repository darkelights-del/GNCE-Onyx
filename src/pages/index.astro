---
/**
 * Home — a real WebGL take. The ONYX word is four extruded-geometry letters
 * (onyx3d.ts) the camera tracks across; each letter's content is born from
 * the frame as it fills the view. Crisp at every distance, real depth.
 *
 * Without WebGL / under reduced motion it degrades to a static, readable
 * stacked page (html.no3d): a CSS wordmark and the same content in sections.
 */
import BaseLayout from '../layouts/BaseLayout.astro';

const base = import.meta.env.BASE_URL.replace(/\/+$/, '');

const numbers = ['22489', '26112', '26413', '26111'];
const roster = 'Ethan Zhang · Ethan Zhuang · Anson Su · Adrian Chang · Leo Li · Nicholas Colli · Raymond Liu';
---

<BaseLayout
  title="Home"
  description="GNCE Onyx is a rookie FIRST Tech Challenge team at Weston High School, built by championship veterans, competing in the 2026-2027 BIOBUZZ season."
>
  <section class="onyx3d" data-onyx3d aria-label="GNCE Onyx">
    <div class="onyx3d-stage">
      <canvas class="onyx3d-canvas" data-onyx-canvas aria-hidden="true"></canvas>

      <!-- Static wordmark for the no-WebGL / reduced-motion page -->
      <p class="onyx3d-wordmark type-display" aria-hidden="true">ONYX</p>

      <div class="onyx3d-overlay">
        <!-- O: who we are -->
        <div class="flow" data-flow="0">
          <div class="flow-inner">
            <p class="flow-line flow-eyebrow type-label text-muted">First Tech Challenge · Weston, MA</p>
            <p class="flow-line flow-script type-script">GNCE Onyx</p>
            <h1 class="flow-line flow-hero type-display">A rookie team of championship veterans.</h1>
            <p class="flow-line flow-support">Built for the 2026-2027 BIOBUZZ season, presented by RTX.</p>
            <p class="flow-line flow-cta">
              <a href={`${base}/contact/`} class="btn btn-solid" data-magnetic="0.4">Sponsor the team</a>
              <a href={`${base}/season/`} class="flow-link">Our first season</a>
            </p>
          </div>
        </div>

        <!-- N: where we come from -->
        <div class="flow flow-right" data-flow="1">
          <div class="flow-inner">
            <p class="flow-line flow-eyebrow type-label text-muted">Where we come from</p>
            <h2 class="flow-line flow-hero type-display">Four of our seven are GNCE veterans.</h2>
            <p class="flow-line flow-support">World championship and international records behind them.</p>
            <p class="flow-line flow-meta type-label text-muted">{numbers.join('  ·  ')}</p>
          </div>
        </div>

        <!-- Y: our robot -->
        <div class="flow" data-flow="2">
          <div class="flow-inner">
            <p class="flow-line flow-eyebrow type-label text-muted">Our robot</p>
            <h2 class="flow-line flow-hero type-display">Designs we can fix in the pit and trust on the field.</h2>
            <p class="flow-line flow-support">Proven where it counts. The build starts at kickoff.</p>
            <p class="flow-line flow-meta type-label text-muted">Size, weight, drivetrain <span class="stub" title="Set at kickoff">TBD</span></p>
          </div>
        </div>

        <!-- X: the crew + close -->
        <div class="flow flow-right" data-flow="3">
          <div class="flow-inner">
            <p class="flow-line flow-eyebrow type-label text-muted">The crew</p>
            <h2 class="flow-line flow-hero type-display flow-hero-sm">{roster}</h2>
            <p class="flow-line flow-support">Two or three more, joining soon.</p>
            <p class="flow-line flow-cta">
              <a href={`${base}/contact/`} class="btn btn-solid" data-magnetic="0.4">Back the build</a>
            </p>
          </div>
        </div>
      </div>

      <p class="onyx3d-cue type-label text-muted" data-onyx-cue>Scroll</p>
    </div>
  </section>
</BaseLayout>

<script>
  import '../scripts/onyx3d';
</script>

<style>
  .onyx3d {
    position: relative;
  }

  .onyx3d-stage {
    position: relative;
    height: 100svh;
    overflow: clip;
  }

  .onyx3d-canvas {
    display: none;
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
  }

  :global(html.onyx-live) .onyx3d-canvas {
    display: block;
  }

  /* Cinematic vignette: darken the frame edges (inset shadow, not a gradient). */
  :global(html.onyx-live) .onyx3d-stage::after {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 2;
    pointer-events: none;
    box-shadow: inset 0 0 clamp(90px, 17vw, 260px) clamp(24px, 6vw, 110px) rgba(10, 9, 8, 0.92);
  }

  /* Static CSS wordmark: shown until the 3D scene takes over. */
  .onyx3d-wordmark {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0;
    font-size: clamp(4rem, 22vw, 16rem);
    letter-spacing: 0.04em;
    color: transparent;
    -webkit-text-stroke: 1.5px color-mix(in srgb, var(--color-ink) 55%, transparent);
    pointer-events: none;
  }

  :global(html.onyx-live) .onyx3d-wordmark {
    display: none;
  }

  .onyx3d-overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    display: grid;
    place-items: center;
    pointer-events: none;
  }

  .flow {
    grid-area: 1 / 1;
    width: min(88vw, 44rem);
    pointer-events: none;
  }

  .flow-right {
    justify-self: end;
    width: min(80vw, 40rem);
  }

  .flow-inner {
    display: flex;
    flex-direction: column;
    gap: clamp(0.7rem, 1.7vw, 1.2rem);
  }

  .flow-line {
    will-change: transform, clip-path;
  }

  .flow-eyebrow {
    margin-bottom: 0.2rem;
  }

  .flow-script {
    font-size: clamp(2rem, 6vw, 3.6rem);
    color: var(--color-accent);
    line-height: 0.9;
  }

  .flow-hero {
    font-size: clamp(2.1rem, 5.2vw, 3.9rem);
    line-height: 1.03;
    max-width: 18ch;
  }

  .flow-hero-sm {
    font-size: clamp(1.4rem, 3vw, 2.1rem);
    line-height: 1.25;
    max-width: 26ch;
  }

  .flow-support {
    max-width: 34ch;
    color: var(--color-muted);
    font-size: 1.0625rem;
  }

  .flow-meta {
    letter-spacing: 0.16em;
  }

  .flow-cta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1.5rem;
    pointer-events: auto;
    margin-top: 0.6rem;
  }

  .flow-link {
    color: var(--color-ink);
    font-weight: 700;
    font-size: 0.9375rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-decoration: underline;
    text-underline-offset: 0.35em;
    text-decoration-color: var(--color-accent);
  }

  .onyx3d-cue {
    position: absolute;
    left: 50%;
    bottom: clamp(1.5rem, 4vh, 2.5rem);
    z-index: 1;
    transform: translateX(-50%);
    pointer-events: none;
  }

  .onyx3d-cue::after {
    content: '';
    display: block;
    width: 1px;
    height: 2.2rem;
    margin: 0.6rem auto 0;
    background: var(--color-line);
  }

  /* Loading splash: JS is present but the scene hasn't taken over yet.
     Show just the centered wordmark so the swap to the canvas is seamless
     (no flash of the stacked fallback). */
  :global(html.js:not(.onyx-live):not(.no3d)) .flow {
    visibility: hidden;
  }

  /* ---- Static fallback (no WebGL / reduced motion / no JS) ----------
     Lay the content out as a normal stacked, readable page. */
  :global(html.no-js) .onyx3d-stage,
  :global(html.no3d) .onyx3d-stage {
    height: auto;
    overflow: visible;
    padding-bottom: 2rem;
  }

  :global(html.no-js) .onyx3d-wordmark,
  :global(html.no3d) .onyx3d-wordmark {
    position: relative;
    inset: auto;
    height: 58svh;
    min-height: 20rem;
  }

  :global(html.no-js) .onyx3d-overlay,
  :global(html.no3d) .onyx3d-overlay {
    position: static;
    display: block;
  }

  :global(html.no-js) .flow,
  :global(html.no3d) .flow {
    visibility: visible;
    width: auto;
    max-width: 44rem;
    margin: 0 auto;
    padding: 3rem clamp(1.25rem, 6vw, 6rem);
    border-top: 1px solid var(--color-line);
  }

  :global(html.no-js) .flow-right,
  :global(html.no3d) .flow-right {
    justify-self: auto;
  }

  :global(html.no-js) .onyx3d-cue,
  :global(html.no3d) .onyx3d-cue {
    display: none;
  }
</style>
