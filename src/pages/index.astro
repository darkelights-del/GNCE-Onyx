---
/**
 * Home — the ONYX experience.
 * A 3D extruded wordmark runs behind the whole page, handing off
 * O -> N -> Y -> X as you scroll (motion.ts, initOnyxSpine). Sections:
 * Hero (O) -> Lineage card-stack (N) -> Mission + Robot (Y) ->
 * Roster coverflow + Back the build (X). Every scene is scroll-driven.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import Placeholder from '../components/Placeholder.astro';
import Reveal from '../components/Reveal.astro';

const base = import.meta.env.BASE_URL.replace(/\/+$/, '');
const glyphs = ['O', 'N', 'Y', 'X'];

const lineage = [
  {
    num: '22489',
    name: 'GNCE Diamond',
    honors: [
      '2025 States, Winning Alliance Captain',
      '2025 World Championship, Jemison: Motivate 2nd',
      '2026 States, Innovate Award',
      '2026 MTI, Mechatronics Synergy Winner',
    ],
  },
  {
    num: '26112',
    name: 'GNCE Organized Anarchy',
    honors: [
      '2025 States, Finalist Alliance Captain',
      '2026 States, Finalist Alliance Captain',
      '2026 World Championship, Jackson: Semifinalist',
      '2026 MTI qualification',
    ],
  },
  { num: '26413', name: 'GNCE Mercury', honors: [] },
  { num: '26111', name: 'GNCE Electrified Chickens', honors: [] },
];

const roster = [
  { name: 'Ethan Zhang', role: 'Captain' },
  { name: 'Ethan Zhuang', role: 'Captain' },
  { name: 'Anson Su', role: '' },
  { name: 'Adrian Chang', role: '' },
  { name: 'Leo Li', role: '' },
  { name: 'Nicholas Colli', role: '' },
  { name: 'Raymond Liu', role: '' },
];

const specs = ['Size', 'Mass', 'Drivetrain', 'TeleOp', 'Auto', 'Solo score'];
---

<BaseLayout
  title="Home"
  description="GNCE Onyx is a rookie FIRST Tech Challenge team at Weston High School, built by championship veterans, competing in the 2026-2027 BIOBUZZ season."
>
  <!-- ===================================== 3D ONYX SPINE (background) -->
  <div class="onyx-spine scene-3d" aria-hidden="true">
    {
      glyphs.map((ch) => (
        <div class="onyx-letter preserve-3d">
          {Array.from({ length: 10 }).map((_, d) => (
            <span class="onyx-face" style={`transform:translate(-50%,-50%) translateZ(${-d * 2.5}px)`}>
              {ch}
            </span>
          ))}
        </div>
      ))
    }
  </div>

  <!-- ============================================= HERO / O -->
  <section class="hero" data-hero>
    <div class="mx-auto w-full max-w-5xl px-5 sm:px-8">
      <p class="type-label text-muted">FIRST Tech Challenge · Weston, MA</p>

      <h1 class="hero-word type-display" aria-label="Onyx">
        {glyphs.map((ch) => (
          <span class="hero-glyph-mask" aria-hidden="true"><span class="hero-glyph">{ch}</span></span>
        ))}
      </h1>

      <p class="hero-script type-script" aria-hidden="true">GNCE Onyx</p>

      <div class="hero-tail">
        <p class="hero-sub">
          A rookie robotics team of championship veterans, built for the
          2026-2027 BIOBUZZ season.
        </p>
        <p class="hero-cta">
          <a href={`${base}/contact/`} class="btn btn-solid" data-magnetic="0.4">Sponsor the team</a>
          <a href={`${base}/season/`} class="hero-link">Our first season</a>
        </p>
      </div>
    </div>
  </section>

  <!-- ============================================= LINEAGE / N -->
  <section class="band">
    <div class="mx-auto w-full max-w-5xl px-5 sm:px-8">
      <h2 class="type-display headline" data-split>Where we come from</h2>
      <Reveal variant="up" class="mt-6 max-w-xl">
        <p class="text-muted">
          Four of our seven members return from four GNCE teams, with world
          championship and international invitational records.
        </p>
      </Reveal>
    </div>

    <!-- Pinned card stack: one heritage team at a time -->
    <div class="stack" data-stack>
      <div class="stack-inner mx-auto w-full max-w-3xl px-5 sm:px-8">
        {
          lineage.map((team) => (
            <article class="stack-card glass" data-stack-card>
              <p class="type-display card-num">{team.num}</p>
              <h3 class="type-display card-name">{team.name}</h3>
              {team.honors.length > 0 ? (
                <ul class="card-honors">
                  {team.honors.map((h) => (
                    <li class="hairline">{h}</li>
                  ))}
                </ul>
              ) : (
                <p class="text-muted card-rookie">First full season with Onyx.</p>
              )}
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ============================================= MISSION / Y -->
  <section class="band mission">
    <div class="mx-auto w-full max-w-5xl px-5 sm:px-8">
      <p class="type-display mission-line" data-split>
        We build robots we understand end to end, so we can fix them in the
        pit and trust them on the field.
      </p>
    </div>
  </section>

  <!-- ============================================= THE ROBOT / Y -->
  <section class="band">
    <div class="mx-auto w-full max-w-5xl px-5 sm:px-8">
      <h2 class="type-display headline" data-split>The machine</h2>

      <div class="mt-12 grid gap-10 md:grid-cols-[1.1fr_1fr]">
        <div data-reveal-scrub="up">
          <Placeholder name="home-robot-photo">
            <div class="slot aspect-[4/3]">
              <span class="type-label text-muted">Robot, at kickoff</span>
            </div>
          </Placeholder>
        </div>

        <div>
          <p class="max-w-prose text-muted">
            The BIOBUZZ build starts at kickoff. This is where the machine
            takes shape, from first sketch to competition ready.
          </p>
          <dl class="specs" data-reveal-group>
            {
              specs.map((key) => (
                <Reveal as="div" class="spec-row hairline">
                  <dt class="type-label text-muted">{key}</dt>
                  <dd class="stub" title="Set at kickoff">TBD</dd>
                </Reveal>
              ))
            }
          </dl>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================= ROSTER / X -->
  <section class="band">
    <div class="mx-auto w-full max-w-5xl px-5 sm:px-8">
      <h2 class="type-display headline" data-split>The crew</h2>
      <Reveal variant="up" class="mt-6 max-w-xl">
        <p class="text-muted">
          Seven and counting, led by two captains. Drag through.
        </p>
      </Reveal>
    </div>

    <div class="swiper roster" data-coverflow>
      <div class="swiper-wrapper">
        {
          roster.map((m) => (
            <div class="swiper-slide roster-slide glass">
              <span class="roster-name type-display">{m.name}</span>
              {m.role && <span class="roster-role type-label text-accent">{m.role}</span>}
            </div>
          ))
        }
        <div class="swiper-slide roster-slide roster-open">
          <span class="text-muted">Two or three more, joining soon.</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================= BACK THE BUILD / X -->
  <section class="band closing">
    <div class="mx-auto w-full max-w-5xl px-5 sm:px-8">
      <h2 class="type-display headline-xl" data-split>Back the build</h2>
      <Reveal variant="up" class="mt-8 max-w-2xl">
        <p class="text-muted">
          Sponsorship covers what a season costs: parts, tools, registration,
          and travel. Cash is one way in. Mentorship and shop tours count too.
        </p>
      </Reveal>
      <Reveal variant="up" class="mt-10">
        <a href={`${base}/contact/`} class="btn btn-solid" data-magnetic="0.4">Sponsor the team</a>
      </Reveal>
    </div>
  </section>
</BaseLayout>

<style>
  /* ---- 3D ONYX spine ------------------------------------------- */
  .onyx-spine {
    position: fixed;
    inset: 0;
    z-index: 0;
    display: grid;
    place-items: center;
    pointer-events: none;
    opacity: 0;
  }

  main > :global(section) {
    position: relative;
    z-index: 1;
  }

  .onyx-letter {
    position: absolute;
    inset: 0;
  }

  .onyx-face {
    position: absolute;
    top: 50%;
    left: 50%;
    font-family: var(--font-display);
    font-size: clamp(20rem, 64vh, 42rem);
    line-height: 1;
    color: var(--color-surface);
  }

  /* front-most face reads a touch lighter for a defined edge (solid step, no gradient) */
  .onyx-letter .onyx-face:first-child {
    color: var(--color-panel);
  }

  /* ---- Hero / O ------------------------------------------------ */
  .hero {
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: clamp(4rem, 10vh, 8rem) 0;
  }

  .hero-word {
    display: flex;
    gap: clamp(0.1rem, 1vw, 0.6rem);
    margin-top: 1rem;
    font-size: clamp(3.5rem, 17vw, 13rem);
    line-height: 0.95;
  }

  .hero-glyph-mask {
    display: inline-block;
    overflow: clip;
    padding: 0 0.02em 0.1em;
  }

  .hero-glyph {
    display: inline-block;
  }

  .hero-script {
    margin-top: 0.25rem;
    font-size: clamp(2rem, 7vw, 4.5rem);
    color: var(--color-accent);
  }

  .hero-sub {
    margin-top: 2.5rem;
    max-width: 34rem;
    color: var(--color-muted);
  }

  .hero-cta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1.5rem;
    margin-top: 1.75rem;
  }

  .hero-link {
    color: var(--color-ink);
    font-family: var(--font-text);
    font-weight: 700;
    font-size: 0.9375rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-decoration: underline;
    text-underline-offset: 0.35em;
    text-decoration-color: var(--color-accent);
    transition: color 200ms ease;
  }

  @media (hover: hover) and (pointer: fine) {
    .hero-link:hover {
      color: var(--color-accent);
    }
  }

  /* ---- Section rhythm (transparent, so the spine shows) -------- */
  .band {
    padding: clamp(6rem, 14vh, 11rem) 0;
  }

  .headline {
    font-size: clamp(2.25rem, 6vw, 4.5rem);
  }

  .headline-xl {
    font-size: clamp(2.75rem, 9vw, 7rem);
  }

  /* ---- Lineage card stack / N --------------------------------- */
  .stack {
    position: relative;
    margin-top: 3rem;
  }

  .stack-inner {
    position: relative;
    height: 100svh;
    display: grid;
    place-items: center;
  }

  .stack-card {
    grid-area: 1 / 1;
    width: 100%;
    padding: clamp(1.5rem, 4vw, 2.75rem);
    background: color-mix(in srgb, var(--color-panel) 88%, transparent);
    will-change: transform, opacity;
  }

  .card-num {
    font-size: clamp(2.5rem, 6vw, 4rem);
    color: var(--color-accent);
    line-height: 1;
  }

  .card-name {
    margin-top: 0.5rem;
    font-size: clamp(1.5rem, 3.5vw, 2.5rem);
  }

  .card-honors {
    margin-top: 1.5rem;
  }

  .card-honors li {
    border-top: 1px solid var(--color-line);
    padding: 0.7rem 0;
    color: var(--color-muted);
    font-size: 0.95rem;
  }

  .card-rookie {
    margin-top: 1.25rem;
  }

  /* ---- Mission / Y -------------------------------------------- */
  .mission-line {
    max-width: 24ch;
    font-size: clamp(1.75rem, 4.5vw, 3.75rem);
    line-height: 1.1;
  }

  /* ---- The machine / specs ------------------------------------ */
  .specs {
    margin-top: 2rem;
  }

  .spec-row {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1.5rem;
    border-top: 1px solid var(--color-line);
    padding: 0.85rem 0;
  }

  .spec-row:last-child {
    border-bottom: 1px solid var(--color-line);
  }

  /* ---- Roster coverflow / X ----------------------------------- */
  .roster {
    margin-top: 3rem;
    padding: 1rem 0 2rem;
    overflow: visible;
  }

  .roster-slide {
    width: min(74vw, 22rem);
    aspect-ratio: 3 / 4;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    gap: 0.5rem;
    padding: 1.75rem;
  }

  .roster-name {
    font-size: clamp(1.5rem, 3vw, 2.1rem);
    line-height: 1.05;
  }

  .roster-open {
    align-items: flex-start;
    justify-content: center;
    border: 1px dashed var(--color-line);
    background: transparent;
    backdrop-filter: none;
    -webkit-backdrop-filter: none;
    text-align: left;
  }

  /* ---- Closing ------------------------------------------------ */
  .closing {
    padding-bottom: clamp(7rem, 18vh, 13rem);
  }
</style>
