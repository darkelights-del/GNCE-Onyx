---
/**
 * Contact + Donate — how to reach the team, and how to support it.
 * Header → Contact (form link + channels) → Sponsor us (money +
 * recognition ladder) → Partner with us (STEM partnerships).
 * Form link / email / Instagram are pending: marked with .stub or <Placeholder>.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import Placeholder from '../components/Placeholder.astro';
import Reveal from '../components/Reveal.astro';
import SectionLabel from '../components/SectionLabel.astro';

const stemTies = [
  {
    name: 'Mentorship',
    desc: 'Design reviews and career talks from working engineers.',
  },
  {
    name: 'Public STEM events',
    desc: 'Show up with us at demos and fairs around Weston.',
  },
  {
    name: 'Joint outreach',
    desc: 'Co-host workshops that get younger students building.',
  },
  {
    name: 'Site visits',
    desc: 'Open your shop, lab, or office for a team tour.',
  },
];

const tiers = [
  { range: 'Under $100', adds: 'Parts money. Same portfolio and site listing as everyone.' },
  { range: '$100-500', adds: '+ a thank-you post on the team Instagram' },
  { range: '$500-1k', adds: '+ your banner in our competition pit' },
  { range: '$1k-2k', adds: '+ your name on the team shirts' },
  { range: '$2k+', adds: '+ all of it, plus a seat at the events we run' },
];
---

<BaseLayout
  title="Contact + Donate"
  description="Contact GNCE Onyx or sponsor our 2026-2027 BIOBUZZ season. Sponsorship covers parts, tools, registration, and travel, and the best partnerships add mentorship and community STEM events."
>
  <!-- =================================================== PAGE HEADER -->
  <header class="bg-bg pt-36 pb-20 sm:pt-44">
    <div class="mx-auto max-w-5xl px-5 sm:px-8">
      <Reveal variant="clip">
        <h1 class="type-display text-[clamp(2.75rem,9vw,8rem)]">
          Get in <span class="text-accent">touch</span>
        </h1>
      </Reveal>

      <Reveal variant="up" delay={160} class="mt-8 max-w-prose">
        <p class="text-muted">
          Sponsorship, questions, or joining the team: email is fastest.
        </p>
      </Reveal>
    </div>
  </header>

  <!-- ======================================================= CONTACT -->
  <section class="bg-bg py-24 sm:py-28">
    <div class="mx-auto max-w-5xl px-5 sm:px-8">
      <div class="grid gap-12 md:grid-cols-2">
        <!-- Contact form link (form itself lives off-site) -->
        <Reveal variant="left">
          <Placeholder name="contact-form-link" class="flex h-full flex-col p-6 sm:p-8">
            <h2 class="type-label text-muted">Contact form</h2>
            <p class="mt-5 max-w-prose text-muted">
              One short form for everything. It goes to the whole team.
            </p>
            <p class="type-label mt-6 text-muted">Link not wired up yet</p>
            <div class="mt-auto pt-8">
              <a href="#" class="btn btn-solid" title="Form link pending" data-magnetic="0.35">Open the form</a>
            </div>
          </Placeholder>
        </Reveal>

        <!-- Direct channels panel -->
        <Reveal variant="right" delay={120}>
          <Placeholder name="contact-channels" class="h-full bg-surface p-6">
            <h2 class="type-label text-muted">Direct channels</h2>
            <dl class="hairline mt-5 border-t">
              <div class="hairline flex flex-wrap items-baseline justify-between gap-x-6 gap-y-1 border-b py-3">
                <dt class="type-label text-muted">Email</dt>
                <dd class="text-[0.9375rem]">
                  <span class="stub" title="Email pending">[placeholder]@gmail.com</span>
                </dd>
              </div>
              <div class="hairline flex flex-wrap items-baseline justify-between gap-x-6 gap-y-1 border-b py-3">
                <dt class="type-label text-muted">Instagram</dt>
                <dd class="text-[0.9375rem]">
                  <span class="stub" title="Instagram handle pending">@placeholder</span>
                </dd>
              </div>
              <div class="hairline flex flex-wrap items-baseline justify-between gap-x-6 gap-y-1 border-b py-3">
                <dt class="type-label text-muted">Find us</dt>
                <dd class="text-[0.9375rem]">Weston High School, Weston, MA</dd>
              </div>
            </dl>
          </Placeholder>
        </Reveal>
      </div>
    </div>
  </section>

  <!-- ==================================================== SPONSOR US -->
  <section class="ember bg-surface py-28 sm:py-36">
    <div class="mx-auto max-w-5xl px-5 sm:px-8">
      <SectionLabel title="Sponsor us" class="mb-12 sm:mb-16" />

      <h2 class="type-display max-w-4xl text-[clamp(2.5rem,7vw,6rem)]" data-split>
        Every dollar builds robots
      </h2>

      <Reveal variant="up" delay={120} class="mt-10 max-w-2xl">
        <p class="text-muted">
          GNCE Onyx is a rookie FTC team built from championship-level
          veterans, competing in the 2026-2027 BIOBUZZ season out of Weston
          High School. Sponsorship covers what a season costs: parts, tools,
          registration, and travel to regional and championship events.
        </p>
      </Reveal>

      <Reveal variant="up" delay={200} class="mt-14 max-w-2xl">
        <h3 class="type-label text-muted">What sponsors get</h3>
        <p class="mt-4 max-w-prose text-muted">
          Every sponsor, at any amount, is named in the engineering
          portfolio judges read at every event, and listed on this site.
          From there it stacks:
        </p>
        <ul class="mt-5" data-reveal-group>
          {
            tiers.map((tier) => (
              <Reveal as="li" class="hairline flex flex-wrap items-baseline gap-x-6 gap-y-1 border-b py-4">
                <span class="type-label w-28 shrink-0 text-accent">{tier.range}</span>
                <span class="flex-1 text-[0.9375rem] text-muted">{tier.adds}</span>
              </Reveal>
            ))
          }
        </ul>
      </Reveal>

      <Placeholder name="contact-sponsor-packet" class="mt-12 inline-block px-4 py-3">
        <p class="type-label text-muted">Sponsor packet: PDF TBD</p>
      </Placeholder>
    </div>
  </section>

  <!-- ================================================ PARTNER WITH US -->
  <section class="bg-bg py-28 sm:py-36">
    <div class="mx-auto max-w-5xl px-5 sm:px-8">
      <Reveal variant="clip">
        <h2 class="type-display max-w-4xl text-[clamp(2rem,5.5vw,4.5rem)]">
          Partner with us
        </h2>
      </Reveal>

      <Reveal variant="up" delay={120} class="mt-8 max-w-2xl">
        <p class="text-muted">
          Not every partnership starts with a check. We want local companies
          in the room:
        </p>
      </Reveal>

      <div class="mt-10 grid gap-x-12 gap-y-2 sm:grid-cols-2" data-reveal-group>
        {
          stemTies.map((tie, i) => (
            <Reveal class="hairline border-b py-4">
              <div class="flex items-baseline gap-5">
                <span class="type-label text-accent">{String(i + 1).padStart(2, '0')}</span>
                <div>
                  <p class="text-lg font-semibold">{tie.name}</p>
                  <p class="mt-1 text-[0.9375rem] text-muted">{tie.desc}</p>
                </div>
              </div>
            </Reveal>
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>
