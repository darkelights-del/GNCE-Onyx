---
/**
 * Contact + Donate. Header (kinetic) → Contact (form link + channels) →
 * Sponsor us (tier ladder) → Partner with us (staggered rows).
 * Form link / email / Instagram are pending: marked with .stub / <Placeholder>.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import Placeholder from '../components/Placeholder.astro';
import Reveal from '../components/Reveal.astro';

const stemTies = [
  { name: 'Mentorship', desc: 'Design reviews and career talks from working engineers.' },
  { name: 'Public STEM events', desc: 'Show up with us at demos and fairs around Weston.' },
  { name: 'Joint outreach', desc: 'Co-host workshops that get younger students building.' },
  { name: 'Site visits', desc: 'Open your shop, lab, or office for a team tour.' },
];

const tiers = [
  { range: 'Under $100', adds: 'Parts money. Same portfolio and site listing as everyone.' },
  { range: '$100-500', adds: 'A thank-you post on the team Instagram.' },
  { range: '$500-1k', adds: 'Your banner in our competition pit.' },
  { range: '$1k-2k', adds: 'Your name on the team shirts.' },
  { range: '$2k+', adds: 'All of it, plus a seat at the events we run.' },
];
---

<BaseLayout
  title="Contact"
  description="Contact GNCE Onyx or sponsor our 2026-2027 BIOBUZZ season. Sponsorship covers parts, tools, registration, and travel; the best partnerships add mentorship and community STEM events."
>
  <!-- HEADER -->
  <header class="mx-auto max-w-5xl px-5 pt-40 pb-16 sm:px-8 sm:pt-48">
    <h1 class="type-display text-[clamp(3rem,12vw,9rem)]" data-split>Get in touch</h1>
    <Reveal variant="up" class="mt-8 max-w-prose">
      <p class="text-muted">Sponsorship, questions, or joining the team. Email is fastest.</p>
    </Reveal>
  </header>

  <!-- CONTACT -->
  <section class="mx-auto max-w-5xl px-5 py-16 sm:px-8 sm:py-24">
    <div class="grid gap-6 md:grid-cols-2">
      <Reveal variant="up">
        <div class="glass flex h-full flex-col p-6 sm:p-8" data-tilt>
          <h2 class="type-label text-muted">Contact form</h2>
          <p class="mt-5 max-w-prose text-muted">One short form for everything. It goes to the whole team.</p>
          <p class="type-label mt-6 text-muted">Link not wired up yet</p>
          <div class="mt-auto pt-8">
            <a href="#" class="btn btn-solid" title="Form link pending" data-magnetic="0.35">Open the form</a>
          </div>
        </div>
      </Reveal>

      <Reveal variant="up" data-reveal-delay="120">
        <div class="glass h-full p-6 sm:p-8" data-tilt>
          <h2 class="type-label text-muted">Direct channels</h2>
          <dl class="hairline mt-5 border-t">
            <div class="channel hairline border-b">
              <dt class="type-label text-muted">Email</dt>
              <dd><span class="stub" title="Email pending">[placeholder]@gmail.com</span></dd>
            </div>
            <div class="channel hairline border-b">
              <dt class="type-label text-muted">Instagram</dt>
              <dd><span class="stub" title="Handle pending">@placeholder</span></dd>
            </div>
            <div class="channel hairline border-b">
              <dt class="type-label text-muted">Find us</dt>
              <dd>Weston High School, Weston, MA</dd>
            </div>
          </dl>
        </div>
      </Reveal>
    </div>
  </section>

  <!-- SPONSOR US: tier ladder -->
  <section class="mx-auto max-w-5xl px-5 py-28 sm:px-8 sm:py-36">
    <h2 class="type-display text-[clamp(2.5rem,7vw,5.5rem)]" data-split>Every dollar builds robots</h2>
    <Reveal variant="up" class="mt-10 max-w-2xl">
      <p class="text-muted">
        Sponsorship covers what a season costs: parts, tools, registration,
        and travel. Every sponsor, at any amount, is named in the engineering
        portfolio judges read at every event, and listed here. From there it
        stacks.
      </p>
    </Reveal>

    <div class="ladder mt-14" data-ladder>
      {
        tiers.map((tier) => (
          <div class="rung hairline" data-rung>
            <span class="type-display rung-range text-accent">{tier.range}</span>
            <span class="rung-adds text-muted">{tier.adds}</span>
          </div>
        ))
      }
    </div>

    <Placeholder name="contact-sponsor-packet" class="mt-12 inline-block px-4 py-3">
      <p class="type-label text-muted">Sponsor packet, PDF TBD</p>
    </Placeholder>
  </section>

  <!-- PARTNER WITH US -->
  <section class="mx-auto max-w-5xl px-5 py-28 sm:px-8 sm:py-36">
    <h2 class="type-display text-[clamp(2rem,5.5vw,4.5rem)]" data-split>Partner with us</h2>
    <Reveal variant="up" class="mt-8 max-w-2xl">
      <p class="text-muted">Not every partnership starts with a check. We want local companies in the room.</p>
    </Reveal>
    <div class="mt-10 grid gap-x-12 gap-y-2 sm:grid-cols-2" data-reveal-group>
      {
        stemTies.map((tie, i) => (
          <Reveal variant="diag" class="tie hairline border-b">
            <span class="type-label text-accent">{String(i + 1).padStart(2, '0')}</span>
            <div>
              <p class="type-display tie-name">{tie.name}</p>
              <p class="mt-1 text-[0.95rem] text-muted">{tie.desc}</p>
            </div>
          </Reveal>
        ))
      }
    </div>
  </section>
</BaseLayout>

<style>
  .channel {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.25rem 1.5rem;
    border-bottom: 1px solid var(--color-line);
    padding: 0.75rem 0;
  }

  .ladder {
    border-top: 1px solid var(--color-line);
  }

  .rung {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.5rem 2rem;
    border-bottom: 1px solid var(--color-line);
    padding: 1.1rem 0;
    will-change: clip-path;
  }

  .rung-range {
    width: 9rem;
    flex: none;
    font-size: 1.25rem;
  }

  .rung-adds {
    flex: 1;
    min-width: 14rem;
  }

  .tie {
    display: flex;
    align-items: baseline;
    gap: 1.25rem;
    border-bottom: 1px solid var(--color-line);
    padding: 1.1rem 0;
  }

  .tie-name {
    font-size: 1.35rem;
  }
</style>
