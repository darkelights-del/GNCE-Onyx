---
/**
 * Outreach — the team's blog. Each post is markdown in src/content/blog/.
 * Header (kinetic) → post list (line-hover rows) → Bring us in (CTA).
 */
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Reveal from '../../components/Reveal.astro';

const base = import.meta.env.BASE_URL.replace(/\/+$/, '');
const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
---

<BaseLayout
  title="Outreach"
  description="GNCE Onyx's outreach log: robot demos, workshops, and STEM events for younger students in and around Weston, Massachusetts, posted as they happen."
>
  <!-- HEADER -->
  <header class="mx-auto max-w-5xl px-5 pt-40 pb-20 sm:px-8 sm:pt-48">
    <h1 class="type-display text-[clamp(3rem,12vw,9rem)]" data-split>Outreach</h1>
    <Reveal variant="up" class="mt-8 max-w-prose">
      <p class="text-muted">
        Competing is half the mission. The other half is getting younger
        students in and around Weston building, coding, and hooked enough to
        stay. Every event we run gets a post here.
      </p>
    </Reveal>
  </header>

  <!-- TICKER: the kinds of events we run, geared to the scroll -->
  <div class="marquee" data-marquee aria-hidden="true">
    <div class="marquee-track" data-marquee-track>
      <span class="marquee-run type-display">
        Robot demos · school workshops · scout nights · STEM fairs ·&nbsp;
      </span>
      <span class="marquee-run type-display">
        Robot demos · school workshops · scout nights · STEM fairs ·&nbsp;
      </span>
    </div>
  </div>

  <!-- POSTS: line-hover rows, wiping in from alternating sides -->
  <section class="mx-auto max-w-5xl px-5 py-28 sm:px-8 sm:pb-36">
    <div class="hairline border-t" data-reveal-group>
      {
        posts.map((post, i) => (
          <Reveal variant={i % 2 ? 'right' : 'left'}>
            <a class="post-row" href={`${base}/outreach/${post.id}/`}>
              <span class="post-marker" aria-hidden="true" />
              <span class="post-date type-label text-muted">{fmt(post.data.date)}</span>
              <span class="post-body-col">
                <span class="post-title type-display">{post.data.title}</span>
                <span class="post-desc text-muted">{post.data.description}</span>
              </span>
            </a>
          </Reveal>
        ))
      }
    </div>
    {posts.length === 0 && <p class="text-muted">No posts yet.</p>}
  </section>

  <!-- BRING US IN -->
  <section class="mx-auto max-w-5xl px-5 py-28 sm:px-8 sm:py-40">
    <h2 class="type-display text-[clamp(2.5rem,8vw,6rem)]" data-split>Bring us in</h2>
    <p class="mt-10 max-w-2xl text-muted" data-hreveal>
      Running a school event or a scout night? We show up with a robot kids
      can actually drive, and the people who built it.
    </p>
    <Reveal variant="up" class="mt-10">
      <a href={`${base}/contact/`} class="btn btn-solid" data-magnetic="0.4">Get in touch</a>
    </Reveal>
  </section>
</BaseLayout>

<style>
  /* Ticker band: oversized outlined display type, hairline-ruled. Purely
     decorative (aria-hidden); the motion engine gears it to scroll velocity. */
  .marquee {
    overflow: clip;
    border-block: 1px solid var(--color-line);
    padding-block: 1rem;
  }

  .marquee-track {
    display: flex;
    width: max-content;
    will-change: transform;
  }

  .marquee-run {
    white-space: nowrap;
    font-size: clamp(1.9rem, 4.5vw, 3.1rem);
    line-height: 1.1;
    color: transparent;
    -webkit-text-stroke: 1px color-mix(in srgb, var(--color-ink) 38%, transparent);
  }

  .post-row {
    position: relative;
    display: grid;
    grid-template-columns: 9rem 1fr;
    gap: 0 2rem;
    align-items: baseline;
    border-bottom: 1px solid var(--color-line);
    padding: 1.75rem 0 1.75rem 1.5rem;
    text-decoration: none;
    color: var(--color-ink);
    transition: padding-left 300ms var(--ease-out-strong);
  }

  .post-marker {
    position: absolute;
    left: 0;
    top: 2.1rem;
    width: 0;
    height: 2px;
    background: var(--color-accent);
    transition: width 300ms var(--ease-out-strong);
  }

  .post-title {
    display: block;
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    line-height: 1.1;
    transition: color 200ms ease;
  }

  .post-desc {
    display: block;
    margin-top: 0.5rem;
    max-width: 46ch;
    font-size: 0.95rem;
  }

  @media (max-width: 640px) {
    .post-row {
      grid-template-columns: 1fr;
      gap: 0.5rem 0;
    }
  }

  @media (hover: hover) and (pointer: fine) {
    .post-row:hover {
      padding-left: 2.75rem;
    }
    .post-row:hover .post-marker {
      width: 1.75rem;
    }
    .post-row:hover .post-title {
      color: var(--color-accent);
    }
  }
</style>
