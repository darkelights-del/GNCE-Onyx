---
/**
 * Outreach — the team's blog. Every outreach event, demo, and update is
 * a markdown post in src/content/blog/ (see the "How to post" post).
 * Header → post list → Bring us in (CTA to contact).
 */
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Reveal from '../../components/Reveal.astro';
import SectionLabel from '../../components/SectionLabel.astro';

const base = import.meta.env.BASE_URL.replace(/\/+$/, '');
const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
---

<BaseLayout
  title="Outreach"
  description="GNCE Onyx's outreach log: robot demos, workshops, and STEM events for younger students in and around Weston, Massachusetts, posted as they happen."
>
  <!-- PAGE HEADER -->
  <header class="bp-grid bg-bg pt-36 pb-20 sm:pt-44">
    <div class="mx-auto max-w-6xl px-5 sm:px-8">
      <Reveal variant="clip">
        <h1 class="type-display text-[clamp(2.75rem,9vw,8rem)]">
          Out<span class="text-accent">reach</span>
        </h1>
      </Reveal>

      <Reveal variant="up" delay={160} class="mt-8 max-w-prose">
        <p class="text-base/relaxed text-muted">
          Competing is half the mission. The other half is getting younger
          students in and around Weston building, coding, and hooked enough
          to stay. Every event we run gets a post here.
        </p>
      </Reveal>
    </div>
  </header>

  <!-- POSTS -->
  <section class="bg-bg pb-24 sm:pb-32">
    <div class="mx-auto max-w-6xl px-5 sm:px-8">
      <SectionLabel title="Posts" class="mb-10 sm:mb-14" />

      <div class="hairline border-t" data-reveal-group>
        {
          posts.map((post) => (
            <Reveal>
              <a
                class="post-row hairline group grid gap-x-8 gap-y-1 border-b py-6 sm:grid-cols-[9rem_1fr]"
                href={`${base}/outreach/${post.id}/`}
              >
                <p class="type-callout pt-2 text-muted">{fmt(post.data.date)}</p>
                <div>
                  <h2 class="type-display text-xl sm:text-2xl">{post.data.title}</h2>
                  <p class="mt-2 max-w-prose text-sm/relaxed text-muted">
                    {post.data.description}
                  </p>
                </div>
              </a>
            </Reveal>
          ))
        }
      </div>

      {
        posts.length === 0 && (
          <p class="font-mono text-sm text-muted">No posts yet.</p>
        )
      }
    </div>
  </section>

  <!-- BRING US IN -->
  <section class="hairline border-t bg-surface py-28 sm:py-40">
    <div class="mx-auto max-w-6xl px-5 sm:px-8">
      <Reveal variant="clip">
        <h2 class="type-display max-w-5xl text-[clamp(2.5rem,7vw,6rem)]">
          Bring us in
        </h2>
      </Reveal>

      <Reveal variant="up" delay={120} class="mt-10 max-w-2xl">
        <p class="text-base/relaxed text-muted">
          Running a school event or a scout night? We'll show up with a robot
          kids can actually drive, and the people who built it.
        </p>
      </Reveal>

      <Reveal variant="up" delay={200} class="mt-10">
        <a href={`${base}/contact/`} class="btn btn-solid">Get in touch</a>
      </Reveal>
    </div>
  </section>
</BaseLayout>

<style>
  .post-row {
    text-decoration: none;
    transition: background-color 200ms ease;
  }

  @media (hover: hover) and (pointer: fine) {
    .post-row:hover {
      background-color: var(--color-surface);
    }

    .post-row:hover h2 {
      color: var(--color-accent);
      transition: color 200ms ease;
    }
  }
</style>
