---
/**
 * Reveal — scroll-driven entrance wrapper.
 *
 * Elements start hidden (JS-gated, so no-JS users see everything) and
 * animate in when they enter the viewport. Variants and timing live in
 * global.css; the IntersectionObserver lives in BaseLayout.
 *
 * The `clip` variant clips an inner wrapper, not the observed element:
 * a fully clipped target reports an empty intersection in Chromium and
 * the observer would never fire.
 *
 * Put `data-reveal-group` on any parent to auto-stagger its child
 * reveals (60ms apart) without setting delays by hand.
 */
interface Props {
  as?: string;
  variant?: 'up' | 'left' | 'right' | 'scale' | 'clip' | 'diag';
  /** Manual delay in ms (skip when inside a data-reveal-group) */
  delay?: number;
  class?: string;
}
const { as = 'div', variant = 'up', delay = 0, class: cls } = Astro.props;
const Tag = as as 'div';
---

<Tag
  class={cls}
  data-reveal={variant}
  style={delay ? `--reveal-delay:${delay}ms` : undefined}
>
  {
    variant === 'clip' ? (
      <span class="reveal-clip-inner">
        <slot />
      </span>
    ) : (
      <slot />
    )
  }
</Tag>
