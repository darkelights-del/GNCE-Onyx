---
/**
 * GearNav — the gear and the menu behind it.
 *
 * The site's only persistent chrome: a gear pinned to the bottom-right
 * corner that turns with scroll, like it's driving the page. Tapping it
 * opens a full-screen menu: four display-type lines that rise in with a
 * stagger. The gear stays on top and closes it.
 *
 * Footer carries plain-text links, so navigation still works without JS.
 */
const base = import.meta.env.BASE_URL.replace(/\/+$/, '');
const links = [
  { href: `${base}/`, numeral: 'I', label: 'Home' },
  { href: `${base}/season/`, numeral: 'II', label: 'Season' },
  { href: `${base}/outreach/`, numeral: 'III', label: 'Outreach' },
  { href: `${base}/contact/`, numeral: 'IV', label: 'Contact' },
];

// A uniform cog: a solid disc with evenly-spaced scallops cut into the
// rim (circular silhouette, no teeth sticking out) plus a center bore.
function gearPath(notches: number, r: number, notchR: number, boreR: number) {
  const circle = (cx: number, cy: number, rad: number) =>
    `M ${(cx + rad).toFixed(2)},${cy.toFixed(2)} ` +
    `A ${rad},${rad} 0 1 0 ${(cx - rad).toFixed(2)},${cy.toFixed(2)} ` +
    `A ${rad},${rad} 0 1 0 ${(cx + rad).toFixed(2)},${cy.toFixed(2)} Z`;
  let d = circle(0, 0, r);
  const step = (Math.PI * 2) / notches;
  for (let i = 0; i < notches; i++) {
    const a = i * step;
    d += ' ' + circle(Math.cos(a) * r, Math.sin(a) * r, notchR);
  }
  d += ' ' + circle(0, 0, boreR);
  return d;
}
const gear = gearPath(12, 27, 3.6, 8.5);

const current = Astro.url.pathname.replace(/\/+$/, '') || '/';
const isCurrent = (href: string) => (href.replace(/\/+$/, '') || '/') === current;
---

<nav class="gear-nav" id="gear-nav" data-open="false" aria-label="Site">
  <div class="gear-menu" id="gear-menu" inert>
    <ol class="gear-menu-list">
      {
        links.map((link, i) => (
          <li class="gear-menu-item" style={`--i:${i}`}>
            <span class="gear-menu-mask">
              <a
                class="gear-menu-link type-display"
                href={link.href}
                aria-current={isCurrent(link.href) ? 'page' : undefined}
              >
                <span class="gear-menu-numeral type-label" aria-hidden="true">
                  {link.numeral}
                </span>
                {link.label}
              </a>
            </span>
          </li>
        ))
      }
    </ol>

    <div class="gear-menu-foot type-label">
      <p>
        GNCE Onyx · Team <span class="stub" title="Team number pending">#XXXXX</span>
      </p>
      <p>Weston High School</p>
    </div>
  </div>

  <span class="gear-hint type-label" aria-hidden="true">Menu</span>

  <button
    class="gear-toggle"
    type="button"
    aria-expanded="false"
    aria-controls="gear-menu"
    data-gear-toggle
  >
    <span class="gear-spin">
      <svg
        viewBox="-32 -32 64 64"
        width="34"
        height="34"
        aria-hidden="true"
        data-gear-svg
      >
        <path d={gear} fill="currentColor" fill-rule="evenodd"></path>
      </svg>
    </span>
    <span class="sr-only">Open navigation</span>
  </button>
</nav>

<style>
  .gear-nav {
    position: fixed;
    right: 1.5rem;
    bottom: 1.5rem;
    z-index: 95;
  }

  @media (max-width: 640px) {
    .gear-nav {
      right: 1rem;
      bottom: 1rem;
    }
  }

  /* ---- Toggle ---------------------------------------------------- */
  .gear-toggle {
    position: relative;
    z-index: 2;
    display: grid;
    place-items: center;
    width: 60px;
    height: 60px;
    border-radius: 50%;
    border: 1px solid var(--color-line);
    background: var(--color-surface);
    color: var(--color-ink);
    cursor: pointer;
    transition:
      transform 160ms var(--ease-out-strong),
      border-color 200ms ease,
      color 200ms ease;
  }

  .gear-toggle:active {
    transform: scale(0.94);
  }

  .gear-nav[data-open='true'] .gear-toggle {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  .gear-spin {
    display: grid;
    place-items: center;
    transition: transform 300ms var(--ease-spring);
  }

  .gear-nav[data-open='true'] .gear-spin {
    transform: rotate(45deg);
  }

  @media (hover: hover) and (pointer: fine) {
    .gear-toggle:hover {
      border-color: var(--color-accent);
      color: var(--color-accent);
    }

    .gear-nav[data-open='false'] .gear-toggle:hover .gear-spin {
      transform: rotate(15deg);
    }
  }

  .gear-hint {
    position: absolute;
    right: calc(100% + 0.75rem);
    top: 50%;
    translate: 0 -50%;
    z-index: 2;
    color: var(--color-muted);
    white-space: nowrap;
    transition: opacity 200ms ease;
  }

  .gear-nav[data-open='true'] .gear-hint {
    opacity: 0;
  }

  /* ---- Full-screen menu ------------------------------------------ */
  .gear-menu {
    position: fixed;
    inset: 0;
    z-index: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: clamp(1.25rem, 4vw, 4rem);
    background: var(--color-bg);
    opacity: 0;
    visibility: hidden;
    transition:
      opacity 220ms ease,
      visibility 0s linear 220ms;
  }

  .gear-nav[data-open='true'] .gear-menu {
    opacity: 1;
    visibility: visible;
    transition: opacity 260ms ease;
  }

  .gear-menu-list {
    margin: 0;
    padding: 0;
    list-style: none;
  }

  /* Each line rises out of its own mask */
  .gear-menu-mask {
    display: block;
    overflow: hidden;
  }

  .gear-menu-link {
    display: flex;
    align-items: baseline;
    gap: 1.25rem;
    padding: 0.375rem 0;
    font-size: clamp(2.5rem, 9vh, 5rem);
    color: var(--color-ink);
    text-decoration: none;
    transform: translateY(110%);
    transition:
      transform 480ms var(--ease-out-strong),
      color 200ms ease;
  }

  .gear-nav[data-open='true'] .gear-menu-link {
    transform: translateY(0);
    transition-delay: calc(80ms + var(--i) * 55ms), 0ms;
  }

  .gear-menu-numeral {
    color: var(--color-accent);
    min-width: 2.5rem;
  }

  .gear-menu-link[aria-current='page'] {
    color: var(--color-accent);
  }

  @media (hover: hover) and (pointer: fine) {
    .gear-menu-link:hover {
      color: var(--color-accent);
      transform: translateX(0.5rem);
    }
  }

  .gear-menu-foot {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 0.5rem 2rem;
    margin-top: clamp(2rem, 8vh, 4rem);
    padding-top: 1rem;
    border-top: 1px solid var(--color-line);
    color: var(--color-muted);
  }

  @media (prefers-reduced-motion: reduce) {
    .gear-spin,
    .gear-menu,
    .gear-nav[data-open='true'] .gear-menu {
      transition: opacity 180ms ease;
    }

    .gear-menu-link,
    .gear-nav[data-open='true'] .gear-menu-link {
      transform: none;
      transition: color 200ms ease;
      transition-delay: 0ms;
    }
  }
</style>

<script>
  function initGearNav() {
    const nav = document.getElementById('gear-nav');
    if (!nav) return;
    const toggle = nav.querySelector<HTMLButtonElement>('[data-gear-toggle]');
    const menu = nav.querySelector<HTMLElement>('#gear-menu');
    const gearSvg = nav.querySelector<SVGElement>('[data-gear-svg]');
    const srLabel = toggle?.querySelector<HTMLElement>('.sr-only');
    if (!toggle || !menu) return;

    const focusables = () => [
      ...menu.querySelectorAll<HTMLElement>('a[href]'),
      toggle,
    ];

    const setOpen = (open: boolean) => {
      nav.dataset.open = String(open);
      toggle.setAttribute('aria-expanded', String(open));
      document.documentElement.style.overflow = open ? 'hidden' : '';
      if (srLabel) srLabel.textContent = open ? 'Close navigation' : 'Open navigation';
      if (open) {
        menu.removeAttribute('inert');
        menu.querySelector<HTMLAnchorElement>('a')?.focus({ preventScroll: true });
      } else {
        menu.setAttribute('inert', '');
      }
    };

    toggle.addEventListener('click', () => setOpen(nav.dataset.open !== 'true'));
    menu.addEventListener('click', (e) => {
      if ((e.target as HTMLElement).closest('a')) setOpen(false);
    });
    document.addEventListener('keydown', (e) => {
      if (nav.dataset.open !== 'true') return;
      if (e.key === 'Escape') {
        setOpen(false);
        toggle.focus();
        return;
      }
      // Keep Tab inside the open menu (links + the gear button).
      if (e.key === 'Tab') {
        const items = focusables();
        const first = items[0];
        const last = items[items.length - 1];
        if (e.shiftKey && document.activeElement === first) {
          e.preventDefault();
          last.focus();
        } else if (!e.shiftKey && document.activeElement === last) {
          e.preventDefault();
          first.focus();
        }
      }
    });

    // Gear rotates with scroll — transform only, applied inside rAF.
    const reduced = matchMedia('(prefers-reduced-motion: reduce)');
    if (gearSvg && !reduced.matches) {
      let queued = false;
      const spin = () => {
        queued = false;
        gearSvg.style.transform = `rotate(${(window.scrollY * 0.22).toFixed(2)}deg)`;
      };
      window.addEventListener(
        'scroll',
        () => {
          if (!queued) {
            queued = true;
            requestAnimationFrame(spin);
          }
        },
        { passive: true }
      );
      spin();
    }
  }

  initGearNav();
</script>
