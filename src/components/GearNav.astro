---
/**
 * GearNav — the "Orbital Gear Hub".
 *
 * The site's only persistent chrome: a gear pinned to the bottom-right
 * corner. The gear rotates with scroll (like it's driving the page).
 * Tapping it spins the gear and fans out one label bubble per page along
 * an arc; the bubbles stagger in with a springy overshoot.
 *
 * Footer carries plain-text links, so navigation still works without JS.
 */
const base = import.meta.env.BASE_URL.replace(/\/+$/, '');
const links = [
  { href: `${base}/`, short: 'Home', label: 'Home' },
  { href: `${base}/season/`, short: 'Season', label: 'Season Recap' },
  { href: `${base}/outreach/`, short: 'Outreach', label: 'Outreach' },
  { href: `${base}/contact/`, short: 'Contact', label: 'Contact + Donate' },
];

// Fan the bubbles up the left side (button sits bottom-right).
// Angles are hand-spaced (not evenly stepped) so the pills keep even
// vertical gaps and never overlap. Unit vectors are precomputed at
// build time; CSS multiplies by --dist.
const angles = [102, 135, 158, 177];
const nodes = links.map((link, i) => {
  const rad = (angles[i] * Math.PI) / 180;
  return {
    ...link,
    ux: Math.cos(rad).toFixed(4),
    uy: (-Math.sin(rad)).toFixed(4),
  };
});

// A uniform cog: a solid disc with evenly-spaced scallops cut into the
// rim (knurled edge, circular silhouette — no teeth sticking out) plus a
// center bore. Built as one evenodd path.
function gearPath(notches: number, r: number, notchR: number, boreR: number) {
  const circle = (cx: number, cy: number, rad: number) =>
    `M ${(cx + rad).toFixed(2)},${cy.toFixed(2)} ` +
    `A ${rad},${rad} 0 1 0 ${(cx - rad).toFixed(2)},${cy.toFixed(2)} ` +
    `A ${rad},${rad} 0 1 0 ${(cx + rad).toFixed(2)},${cy.toFixed(2)} Z`;
  let d = circle(0, 0, r);
  const step = (Math.PI * 2) / notches;
  for (let i = 0; i < notches; i++) {
    const a = i * step;
    d += ' ' + circle(Math.cos(a) * r, Math.sin(a) * r, notchR);
  }
  d += ' ' + circle(0, 0, boreR);
  return d;
}
const gear = gearPath(12, 27, 3.6, 8.5);

const current = Astro.url.pathname.replace(/\/+$/, '') || '/';
const isCurrent = (href: string) => (href.replace(/\/+$/, '') || '/') === current;
---

<nav class="gear-nav" id="gear-nav" data-open="false" aria-label="Site">
  <div class="gear-backdrop" data-gear-backdrop></div>

  <ul class="gear-ring" id="gear-ring" inert>
    {
      nodes.map((node, i) => (
        <li style={`--ux:${node.ux};--uy:${node.uy};--i:${i}`}>
          <a
            class="gear-bubble"
            href={node.href}
            aria-label={node.label}
            aria-current={isCurrent(node.href) ? 'page' : undefined}
          >
            {node.short}
          </a>
        </li>
      ))
    }
  </ul>

  <span class="gear-hint type-callout" aria-hidden="true">[ nav ]</span>

  <button
    class="gear-toggle"
    type="button"
    aria-expanded="false"
    aria-controls="gear-ring"
    data-gear-toggle
  >
    <span class="gear-spin">
      <svg
        viewBox="-32 -32 64 64"
        width="34"
        height="34"
        aria-hidden="true"
        data-gear-svg
      >
        <path d={gear} fill="currentColor" fill-rule="evenodd"></path>
      </svg>
    </span>
    <span class="sr-only">Open navigation</span>
  </button>
</nav>

<style>
  .gear-nav {
    position: fixed;
    right: 1.5rem;
    bottom: 1.5rem;
    z-index: 50;
    --dist: 134px;
  }

  @media (max-width: 640px) {
    .gear-nav {
      right: 1rem;
      bottom: 1rem;
      --dist: 126px;
    }
  }

  .gear-backdrop {
    position: fixed;
    inset: 0;
    background: color-mix(in srgb, var(--color-bg) 62%, transparent);
    -webkit-backdrop-filter: blur(6px);
    backdrop-filter: blur(6px);
    opacity: 0;
    visibility: hidden;
    transition:
      opacity 240ms ease,
      visibility 0s linear 240ms;
  }

  .gear-nav[data-open='true'] .gear-backdrop {
    opacity: 1;
    visibility: visible;
    transition: opacity 240ms ease;
  }

  /* ---- Toggle ---------------------------------------------------- */
  .gear-toggle {
    position: relative;
    display: grid;
    place-items: center;
    width: 60px;
    height: 60px;
    border-radius: 50%;
    border: 1px solid var(--color-line);
    background: var(--color-panel);
    color: var(--color-ink);
    cursor: pointer;
    transition:
      transform 160ms var(--ease-out-strong),
      border-color 200ms ease,
      color 200ms ease;
  }

  .gear-toggle:active {
    transform: scale(0.94);
  }

  .gear-nav[data-open='true'] .gear-toggle {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  .gear-spin {
    display: grid;
    place-items: center;
    transition: transform 300ms var(--ease-spring);
  }

  .gear-nav[data-open='true'] .gear-spin {
    transform: rotate(45deg);
  }

  @media (hover: hover) and (pointer: fine) {
    .gear-toggle:hover {
      border-color: var(--color-accent);
      color: var(--color-accent);
    }

    .gear-nav[data-open='false'] .gear-toggle:hover .gear-spin {
      transform: rotate(15deg);
    }
  }

  .gear-hint {
    position: absolute;
    right: calc(100% + 0.75rem);
    top: 50%;
    translate: 0 -50%;
    color: var(--color-muted);
    white-space: nowrap;
    transition: opacity 200ms ease;
  }

  .gear-nav[data-open='true'] .gear-hint {
    opacity: 0;
  }

  /* ---- Fan of label bubbles -------------------------------------- */
  .gear-ring {
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .gear-ring li {
    /* Zero-size anchor pinned on the toggle's center; translates out
       along its spoke when the menu opens. */
    position: absolute;
    right: 30px;
    bottom: 30px;
    width: 0;
    height: 0;
    transform: translate(0, 0);
    transition: transform 260ms var(--ease-out-strong);
  }

  .gear-nav[data-open='true'] .gear-ring li {
    transform: translate(calc(var(--ux) * var(--dist)), calc(var(--uy) * var(--dist)));
    transition: transform 320ms var(--ease-spring);
    transition-delay: calc(var(--i) * 45ms);
  }

  .gear-bubble {
    position: absolute;
    right: 0;
    top: 0;
    display: flex;
    align-items: center;
    padding: 0.5rem 0.9rem;
    border: 1px solid var(--color-line);
    border-radius: 999px;
    background: var(--color-panel);
    color: var(--color-ink);
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    text-decoration: none;
    white-space: nowrap;
    opacity: 0;
    transform: translate(10px, -50%) scale(0.9);
    transform-origin: right center;
    transition:
      opacity 140ms ease,
      transform 180ms var(--ease-out-strong),
      border-color 200ms ease,
      background-color 200ms ease,
      color 200ms ease;
  }

  .gear-nav[data-open='true'] .gear-bubble {
    opacity: 1;
    transform: translate(0, -50%) scale(1);
    transition:
      opacity 200ms ease,
      transform 300ms var(--ease-spring),
      border-color 200ms ease,
      background-color 200ms ease,
      color 200ms ease;
    transition-delay: calc(var(--i) * 45ms);
  }

  .gear-bubble:active {
    scale: 0.96;
  }

  .gear-bubble[aria-current='page'] {
    border-color: var(--color-accent);
    background: var(--color-accent);
    color: var(--color-ink);
  }

  @media (hover: hover) and (pointer: fine) {
    .gear-bubble:hover {
      border-color: var(--color-accent);
      background: var(--color-accent);
      color: var(--color-ink);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .gear-spin,
    .gear-ring li,
    .gear-nav[data-open='true'] .gear-ring li,
    .gear-bubble,
    .gear-nav[data-open='true'] .gear-bubble {
      transition:
        opacity 180ms ease,
        border-color 200ms ease,
        background-color 200ms ease,
        color 200ms ease;
      transition-delay: 0ms;
    }

    .gear-ring li,
    .gear-nav[data-open='true'] .gear-ring li {
      transform: translate(calc(var(--ux) * var(--dist)), calc(var(--uy) * var(--dist)));
    }

    .gear-bubble,
    .gear-nav[data-open='true'] .gear-bubble {
      transform: translate(0, -50%);
    }
  }
</style>

<script>
  function initGearNav() {
    const nav = document.getElementById('gear-nav');
    if (!nav) return;
    const toggle = nav.querySelector<HTMLButtonElement>('[data-gear-toggle]');
    const backdrop = nav.querySelector<HTMLElement>('[data-gear-backdrop]');
    const ring = nav.querySelector<HTMLUListElement>('#gear-ring');
    const gearSvg = nav.querySelector<SVGElement>('[data-gear-svg]');
    const srLabel = toggle?.querySelector<HTMLElement>('.sr-only');
    if (!toggle || !ring) return;

    const setOpen = (open: boolean) => {
      nav.dataset.open = String(open);
      toggle.setAttribute('aria-expanded', String(open));
      if (srLabel) srLabel.textContent = open ? 'Close navigation' : 'Open navigation';
      if (open) {
        ring.removeAttribute('inert');
        ring.querySelector<HTMLAnchorElement>('a')?.focus({ preventScroll: true });
      } else {
        ring.setAttribute('inert', '');
      }
    };

    toggle.addEventListener('click', () => setOpen(nav.dataset.open !== 'true'));
    backdrop?.addEventListener('click', () => setOpen(false));
    ring.addEventListener('click', (e) => {
      if ((e.target as HTMLElement).closest('a')) setOpen(false);
    });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && nav.dataset.open === 'true') {
        setOpen(false);
        toggle.focus();
      }
    });

    // Gear rotates with scroll — transform only, applied inside rAF.
    const reduced = matchMedia('(prefers-reduced-motion: reduce)');
    if (gearSvg && !reduced.matches) {
      let queued = false;
      const spin = () => {
        queued = false;
        gearSvg.style.transform = `rotate(${(window.scrollY * 0.22).toFixed(2)}deg)`;
      };
      window.addEventListener(
        'scroll',
        () => {
          if (!queued) {
            queued = true;
            requestAnimationFrame(spin);
          }
        },
        { passive: true }
      );
      spin();
    }
  }

  initGearNav();
</script>
