---
/**
 * Placeholder — wraps any block still waiting on real content.
 *
 * Every placeholder gets a visible dashed frame plus a small-caps tag
 * naming the slot, and a `data-placeholder` attribute so remaining
 * slots can be found in one search:  grep -r "data-placeholder" src/
 *
 * When dropping in real content, remove this wrapper (keep its children).
 */
interface Props {
  /** Short slot name shown in the tag, e.g. "robot-photo" */
  name: string;
  class?: string;
}
const { name, class: cls } = Astro.props;
---

<div class:list={['placeholder', cls]} data-placeholder={name}>
  <span class="placeholder-tag type-label">Placeholder · {name}</span>
  <slot />
</div>

<style>
  .placeholder {
    position: relative;
    border: 1px dashed color-mix(in srgb, var(--color-accent) 55%, var(--color-ink));
  }

  .placeholder-tag {
    position: absolute;
    top: 0;
    right: 0.75rem;
    translate: 0 -50%;
    z-index: 1;
    padding: 0.125rem 0.625rem;
    background: var(--color-bg);
    border: 1px dashed color-mix(in srgb, var(--color-accent) 55%, var(--color-ink));
    color: var(--color-ink);
    font-size: 0.75rem;
    white-space: nowrap;
  }
</style>
