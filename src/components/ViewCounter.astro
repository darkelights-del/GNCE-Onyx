---
/**
 * Per-page view counter via GoatCounter. Counts the visit on load and
 * shows the running total. Renders a marked stub until the site code
 * is configured in src/lib/services.ts (see README, "Blog").
 */
import { GOATCOUNTER_CODE, goatcounterReady } from '../lib/services';
---

{
  goatcounterReady ? (
    <span class="type-label text-muted" data-views>
      Views: <span data-views-n>…</span>
    </span>
  ) : (
    <span class="type-label text-muted stub" title="View counts appear once GoatCounter is configured (see README)">
      Views: TBD
    </span>
  )
}

{
  goatcounterReady && (
    <script
      is:inline
      data-goatcounter={`https://${GOATCOUNTER_CODE}.goatcounter.com/count`}
      src="https://gc.zgo.at/count.js"
      async
    />
  )
}

{
  goatcounterReady && (
    <script is:inline define:vars={{ code: GOATCOUNTER_CODE }}>
      const el = document.querySelector('[data-views-n]');
      if (el) {
        const path = encodeURIComponent(location.pathname);
        fetch(`https://${code}.goatcounter.com/counter/${path}.json`)
          .then((r) => (r.ok ? r.json() : null))
          .then((d) => {
            if (d && el) el.textContent = d.count.trim();
          })
          .catch(() => {});
      }
    </script>
  )
}
