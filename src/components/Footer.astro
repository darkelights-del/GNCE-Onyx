---
/**
 * Footer — plain-text navigation (the no-JS fallback for the gear hub)
 * plus team identity and contact lines.
 */
const links = [
  { href: '/', label: 'Home' },
  { href: '/season/', label: 'Season Recap' },
  { href: '/contact/', label: 'Contact + Donate' },
];
---

<footer class="border-t hairline bg-surface">
  <div class="mx-auto max-w-6xl px-5 py-14 sm:px-8">
    <div class="grid gap-10 sm:grid-cols-3">
      <div>
        <p class="type-display text-2xl">GNCE Onyx</p>
        <p class="type-callout mt-3 text-muted">
          FIRST Tech Challenge team <span class="stub" title="Team number pending">#XXXXX</span>
        </p>
        <p class="type-callout mt-1 text-muted">Weston High School, Weston, MA</p>
      </div>

      <nav aria-label="Footer">
        <p class="type-callout text-muted">Index</p>
        <ul class="mt-4 space-y-2">
          {
            links.map((link) => (
              <li>
                <a
                  class="footer-link font-mono text-sm text-ink"
                  href={link.href}
                >
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>

      <div>
        <p class="type-callout text-muted">Reach us</p>
        <ul class="mt-4 space-y-2 font-mono text-sm text-muted">
          <li>
            <span class="stub" title="Email pending">[placeholder]@gmail.com</span>
          </li>
          <li>
            <span class="stub" title="Instagram handle pending">@placeholder</span>
          </li>
        </ul>
      </div>
    </div>

    <div
      class="type-callout mt-12 flex flex-wrap items-center justify-between gap-3 border-t hairline pt-6 text-muted"
    >
      <p>© 2026 GNCE Onyx</p>
      <p>Rookie season: 2026-2027 BIOBUZZ</p>
    </div>
  </div>
</footer>

<style>
  .footer-link {
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition:
      color 200ms ease,
      border-color 200ms ease;
  }

  @media (hover: hover) and (pointer: fine) {
    .footer-link:hover {
      color: var(--color-accent);
      border-color: var(--color-accent);
    }
  }
</style>
