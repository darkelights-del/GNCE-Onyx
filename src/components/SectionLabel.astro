---
/**
 * SectionLabel — a small-caps label with a short ember rule, used to
 * open at most a couple of sections per page. Pass `index` only when
 * the order itself is content (e.g. the season timeline).
 */
interface Props {
  title: string;
  index?: string;
  class?: string;
}
const { index, title, class: cls } = Astro.props;
---

<p class:list={['section-label type-label', cls]}>
  <span class="section-label-rule" aria-hidden="true"></span>
  <span>{index ? `${index} · ${title}` : title}</span>
</p>

<style>
  .section-label {
    display: flex;
    align-items: center;
    gap: 0.875rem;
    color: var(--color-muted);
  }

  .section-label-rule {
    width: 2.25rem;
    height: 3px;
    background: var(--color-accent);
  }
</style>
