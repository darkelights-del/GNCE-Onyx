---
/**
 * SectionLabel — engineering-drawing callout that opens every section:
 * [ 02 / THE ROBOT ] ————————————————
 */
interface Props {
  index: string;
  title: string;
  class?: string;
}
const { index, title, class: cls } = Astro.props;
---

<p class:list={['section-label type-callout', cls]}>
  <span class="text-accent" aria-hidden="true">[</span>
  <span>{index} / {title}</span>
  <span class="text-accent" aria-hidden="true">]</span>
  <span class="section-label-rule" aria-hidden="true"></span>
</p>

<style>
  .section-label {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    color: var(--color-muted);
  }

  .section-label-rule {
    flex: 1;
    height: 1px;
    background: var(--color-line);
  }
</style>
