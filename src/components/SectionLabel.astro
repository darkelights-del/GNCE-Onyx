---
/**
 * SectionLabel — engineering-drawing callout that opens a section:
 * [ THE ROBOT ] ———————————————— or, where order is real content
 * (e.g. a timeline), [ 01 / KICKOFF ] ————————————————
 *
 * Use sparingly (not on every section) and only pass `index` when the
 * sequence itself carries information.
 */
interface Props {
  title: string;
  index?: string;
  class?: string;
}
const { index, title, class: cls } = Astro.props;
---

<p class:list={['section-label type-callout', cls]}>
  <span class="text-accent" aria-hidden="true">[</span>
  <span>{index ? `${index} / ${title}` : title}</span>
  <span class="text-accent" aria-hidden="true">]</span>
  <span class="section-label-rule" aria-hidden="true"></span>
</p>

<style>
  .section-label {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    color: var(--color-muted);
  }

  .section-label-rule {
    flex: 1;
    height: 1px;
    background: var(--color-line);
  }
</style>
