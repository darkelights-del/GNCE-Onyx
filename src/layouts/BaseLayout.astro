---
/**
 * BaseLayout — the single shared shell for every page.
 *
 * Owns: fonts, global styles, the intro cover (once per session), the
 * scroll heat rail, cross-page view transitions, GearNav, footer, and
 * the motion engine that drives every scroll animation
 * (see src/scripts/motion.ts).
 */
import '@fontsource/uncial-antiqua';
import '@fontsource/grey-qo';
import '@fontsource/cardo/400.css';
import '@fontsource/cardo/700.css';
import '@fontsource/cardo/400-italic.css';
import '../styles/global.css';
import Footer from '../components/Footer.astro';
import GearNav from '../components/GearNav.astro';

interface Props {
  title: string;
  description?: string;
}
const {
  title,
  description = 'GNCE Onyx: a rookie FIRST Tech Challenge team at Weston High School, built by veterans of four GNCE squads, competing in the 2026-2027 BIOBUZZ season.',
} = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/+$/, '');
---

<!doctype html>
<html lang="en" class="no-js">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
    <meta name="generator" content={Astro.generator} />
    <title>{title} · GNCE Onyx</title>
    <script is:inline>
      document.documentElement.classList.replace('no-js', 'js');
      // Set motion flags synchronously, before first paint, so the page
      // never flashes the pre-animation state. The motion module clears
      // these once it boots; the failsafes clear them if it never does.
      try {
        if (!matchMedia('(prefers-reduced-motion: reduce)').matches) {
          document.documentElement.classList.add('will-animate');
          setTimeout(function () {
            document.documentElement.classList.remove('will-animate');
          }, 2600);
          // Intro cover: once per session. The load meter (just below
          // <body>) counts up with real font loading and lifts the cover
          // itself; this timeout is only a last resort so the cover can
          // never get stuck if that script fails to run.
          if (!sessionStorage.getItem('intro-seen')) {
            document.documentElement.classList.add('loading');
            setTimeout(function () {
              document.documentElement.classList.remove('loading');
              try {
                sessionStorage.setItem('intro-seen', '1');
              } catch (e) {
                /* storage blocked */
              }
            }, 4500);
          }
        }
      } catch (e) {
        /* storage blocked: skip the loader */
      }
    </script>
  </head>
  <body class="min-h-svh bg-bg text-ink antialiased">
    <a class="skip-link" href="#main">Skip to content</a>

    <!-- Intro cover: a load meter counts up in time with the fonts, then
         the cover lifts into the hero's entrance. Skipped after first view. -->
    <div class="intro" data-intro aria-hidden="true">
      <div class="intro-loader">
        <p class="intro-count">
          <span class="intro-num" data-intro-num>0</span><span class="intro-pct">%</span>
        </p>
        <div class="intro-gauge"><span class="intro-gauge-fill" data-intro-fill></span></div>
      </div>
    </div>

    <!-- Drives the load meter from real font loading (the "text"). Inline
         so counting starts during parse, before the motion module loads,
         and still runs if that module fails. Only active while the cover
         is up (html.loading), so reduced-motion / repeat visits skip it. -->
    <script is:inline>
      (function () {
        var root = document.documentElement;
        if (!root.classList.contains('loading')) return;
        var numEl = document.querySelector('[data-intro-num]');
        var fillEl = document.querySelector('[data-intro-fill]');
        if (!numEl || !fillEl) return;

        // Real progress: the fraction of the site's font faces that have
        // loaded. document.fonts.ready is the definitive "text is ready".
        var target = 0;
        var fonts = document.fonts;
        if (fonts && fonts.load) {
          var specs = [
            '1em "Uncial Antiqua"',
            '1em "Grey Qo"',
            '1em "Cardo"',
            '700 1em "Cardo"',
            'italic 1em "Cardo"',
          ];
          var loaded = 0;
          var step = function () {
            loaded++;
            target = Math.max(target, loaded / specs.length);
          };
          specs.forEach(function (s) {
            fonts.load(s).then(step, step);
          });
          fonts.ready.then(
            function () {
              target = 1;
            },
            function () {
              target = 1;
            }
          );
        } else {
          target = 1;
        }

        var start = performance.now();
        var MIN = 900; // a real screen, never a flash, even from cache
        var MAX = 3400; // never hang
        var shown = 0;
        var done = false;

        function lift() {
          if (done) return;
          done = true;
          try {
            sessionStorage.setItem('intro-seen', '1');
          } catch (e) {
            /* storage blocked */
          }
          setTimeout(function () {
            window.__introDone = true;
            root.classList.remove('loading');
            document.dispatchEvent(new Event('intro:done'));
          }, 160); // a beat on 100 before the cover lifts
        }

        function frame(now) {
          var elapsed = now - start;
          // Track real loading, but never outrun the time floor, and force
          // it home past MAX. goal only ever rises, so the count is monotonic.
          var goal = elapsed >= MAX ? 1 : Math.min(target, elapsed / MIN);
          shown += (goal - shown) * 0.16;
          if (goal - shown < 0.004) shown = goal;
          if (shown < 0) shown = 0;
          if (shown >= 1) {
            numEl.textContent = '100';
            fillEl.style.transform = 'scaleX(1)';
            lift();
            return;
          }
          numEl.textContent = String(Math.max(0, Math.round(shown * 100)));
          fillEl.style.transform = 'scaleX(' + shown.toFixed(4) + ')';
          requestAnimationFrame(frame);
        }
        requestAnimationFrame(frame);
      })();
    </script>

    <!-- Heat rail: fills with scroll like a gauge. Scroll-driven CSS;
         browsers without support simply never show it. -->
    <div class="heat-rail" aria-hidden="true"></div>

    <main id="main"><slot /></main>

    <Footer />
    <GearNav />

    <!-- The motion engine: GSAP + ScrollTrigger + Lenis, the pinned hero
         and roster, masked split-text, clip-wipe reveals, parallax, and
         magnetic pull. Bows out under reduced motion (static CSS stands in). -->
    <script>
      import '../scripts/motion';
    </script>

    <style>
      /* ---- Intro cover -------------------------------------------- */
      /* Sits offscreen by default; html.loading holds it down over the
         page, and removing the class lifts it into the hero entrance. */
      .intro {
        position: fixed;
        inset: 0;
        z-index: 120;
        display: flex;
        align-items: center;
        justify-content: center;
        background: var(--color-bg);
        transform: translateY(-101%);
        transition: transform 560ms var(--ease-in-out-strong);
        pointer-events: none;
      }

      :global(html.loading) .intro {
        transform: none;
        transition: none;
        pointer-events: auto;
      }

      :global(html.no-js) .intro {
        display: none;
      }

      .intro-loader {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1.4rem;
      }

      /* Tabular Cardo so the digits hold their box while the number climbs. */
      .intro-count {
        overflow: clip;
        display: flex;
        align-items: baseline;
        justify-content: center;
        font-family: var(--font-text);
        font-weight: 700;
        line-height: 0.9;
        color: var(--color-ink);
        font-variant-numeric: tabular-nums lining-nums;
        font-feature-settings: 'tnum' 1, 'lnum' 1;
      }

      .intro-num {
        display: inline-block;
        min-width: 3ch;
        text-align: right;
        font-size: clamp(3rem, 11vw, 7rem);
        transform: translateY(115%);
      }

      .intro-pct {
        margin-left: 0.12em;
        font-size: clamp(1.25rem, 4vw, 2.25rem);
        color: var(--color-muted);
        transform: translateY(115%);
      }

      /* Masked rise on appear (no fade), matching the split-text language. */
      :global(html.loading) .intro-num,
      :global(html.loading) .intro-pct {
        animation: intro-rise 620ms var(--ease-out-strong) 120ms both;
      }

      /* Hairline gauge; the crimson fill is driven by the meter script. */
      .intro-gauge {
        width: clamp(180px, 30vw, 340px);
        height: 2px;
        background: var(--color-line);
      }

      .intro-gauge-fill {
        display: block;
        height: 100%;
        width: 100%;
        background: var(--color-accent);
        transform: scaleX(0);
        transform-origin: 0 50%;
        will-change: transform;
      }

      @keyframes intro-rise {
        to {
          transform: translateY(0);
        }
      }

      /* ---- Heat rail ---------------------------------------------- */
      .heat-rail {
        display: none;
      }

      @supports (animation-timeline: scroll()) {
        .heat-rail {
          display: block;
          position: fixed;
          top: 0;
          left: 0;
          width: 3px;
          height: 100svh;
          z-index: 80;
          background: var(--color-accent);
          transform-origin: 0 0;
          transform: scaleY(0);
          animation: heat-fill linear both;
          animation-timeline: scroll(root);
          pointer-events: none;
        }

        @media (prefers-reduced-motion: reduce) {
          .heat-rail {
            display: none;
          }
        }
      }

      @keyframes heat-fill {
        from {
          transform: scaleY(0);
        }
        to {
          transform: scaleY(1);
        }
      }
    </style>

    <style is:global>
      /* ---- Cross-page continuity (View Transitions, progressive) --- */
      @view-transition {
        navigation: auto;
      }

      ::view-transition-old(root) {
        animation: vt-leave 200ms var(--ease-out-strong) both;
      }

      ::view-transition-new(root) {
        animation: vt-enter 320ms var(--ease-out-strong) both;
      }

      @keyframes vt-leave {
        to {
          opacity: 0;
        }
      }

      @keyframes vt-enter {
        from {
          opacity: 0;
          transform: translateY(12px);
        }
      }

      @media (prefers-reduced-motion: reduce) {
        ::view-transition-old(root),
        ::view-transition-new(root) {
          animation: none;
        }
      }
    </style>
  </body>
</html>
