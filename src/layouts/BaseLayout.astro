---
/**
 * BaseLayout — the single shared shell for every page.
 *
 * Owns: fonts, global styles, the GearNav hub, footer, Lenis smooth
 * scrolling, and the IntersectionObserver that drives [data-reveal]
 * entrances (see Reveal.astro / global.css).
 */
import '@fontsource-variable/archivo/wdth.css';
import '@fontsource-variable/jetbrains-mono';
import '../styles/global.css';
import Footer from '../components/Footer.astro';
import GearNav from '../components/GearNav.astro';

interface Props {
  title: string;
  description?: string;
}
const {
  title,
  description = 'GNCE Onyx: a rookie FIRST Tech Challenge team at Weston High School, built by veterans of four GNCE squads, competing in the 2026-2027 BIOBUZZ season.',
} = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/+$/, '');
---

<!doctype html>
<html lang="en" class="no-js">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
    <meta name="generator" content={Astro.generator} />
    <title>{title} · GNCE Onyx</title>
    <script is:inline>
      document.documentElement.classList.replace('no-js', 'js');
    </script>
  </head>
  <body class="min-h-svh bg-bg font-display text-ink antialiased">
    <a class="skip-link" href="#main">Skip to content</a>

    <main id="main"><slot /></main>

    <Footer />
    <GearNav />

    <script>
      import Lenis from 'lenis';

      const reduced = matchMedia('(prefers-reduced-motion: reduce)').matches;

      // Smooth scrolling — skipped entirely under reduced motion
      // (the CSS scroll-behavior fallback is disabled there too).
      if (!reduced) {
        const lenis = new Lenis({ lerp: 0.12, anchors: true });
        const raf = (time: number) => {
          lenis.raf(time);
          requestAnimationFrame(raf);
        };
        requestAnimationFrame(raf);
      }

      // Auto-stagger reveals inside any [data-reveal-group] (60ms apart,
      // capped so long lists never feel slow).
      document.querySelectorAll('[data-reveal-group]').forEach((group) => {
        group.querySelectorAll<HTMLElement>('[data-reveal]').forEach((el, i) => {
          if (!el.style.getPropertyValue('--reveal-delay')) {
            el.style.setProperty('--reveal-delay', `${Math.min(i * 60, 360)}ms`);
          }
        });
      });

      // Huge top margin: anything at or above the viewport counts as seen,
      // so fast scrolls (scrollbar drags, anchor jumps) can't strand
      // skipped elements in their hidden state above the reader.
      const io = new IntersectionObserver(
        (entries) => {
          for (const entry of entries) {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-revealed');
              io.unobserve(entry.target);
            }
          }
        },
        { threshold: 0.12, rootMargin: '2000% 0px -8% 0px' }
      );
      document.querySelectorAll('[data-reveal]').forEach((el) => io.observe(el));
    </script>
  </body>
</html>
