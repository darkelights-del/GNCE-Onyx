---
/**
 * BaseLayout — the single shared shell for every page.
 *
 * Owns: fonts, global styles, the intro cover (once per session), the
 * scroll heat rail, cross-page view transitions, GearNav, footer, and
 * the motion engine that drives every scroll animation
 * (see src/scripts/motion.ts).
 */
import '@fontsource/uncial-antiqua';
import '@fontsource/grey-qo';
import '@fontsource/cardo/400.css';
import '@fontsource/cardo/700.css';
import '@fontsource/cardo/400-italic.css';
import '../styles/global.css';
import Footer from '../components/Footer.astro';
import GearNav from '../components/GearNav.astro';

interface Props {
  title: string;
  description?: string;
}
const {
  title,
  description = 'GNCE Onyx: a rookie FIRST Tech Challenge team at Weston High School, built by veterans of four GNCE squads, competing in the 2026-2027 BIOBUZZ season.',
} = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/+$/, '');
---

<!doctype html>
<html lang="en" class="no-js">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
    <meta name="generator" content={Astro.generator} />
    <title>{title} · GNCE Onyx</title>
    <script is:inline>
      document.documentElement.classList.replace('no-js', 'js');
      // Set motion flags synchronously, before first paint, so the page
      // never flashes the pre-animation state. The motion module clears
      // these once it boots; the failsafes clear them if it never does.
      try {
        if (!matchMedia('(prefers-reduced-motion: reduce)').matches) {
          document.documentElement.classList.add('will-animate');
          setTimeout(function () {
            document.documentElement.classList.remove('will-animate');
          }, 2600);
          // Intro cover: once per session.
          if (!sessionStorage.getItem('intro-seen')) {
            document.documentElement.classList.add('loading');
            setTimeout(function () {
              document.documentElement.classList.remove('loading');
            }, 2000);
          }
        }
      } catch (e) {
        /* storage blocked: skip the loader */
      }
    </script>
  </head>
  <body class="min-h-svh bg-bg text-ink antialiased">
    <a class="skip-link" href="#main">Skip to content</a>

    <!-- Custom cursor: crimson dot snaps to the pointer, off-white ring
         trails it; ring widens over links. Fine pointers only. -->
    <div class="cursor" data-cursor aria-hidden="true">
      <span class="cursor-dot"></span>
      <span class="cursor-ring"></span>
    </div>

    <!-- Intro cover: the wordmark is struck once, then the cover lifts
         into the hero's entrance. Skipped after first view. -->
    <div class="intro" data-intro aria-hidden="true">
      <p class="intro-mark type-display">
        <span class="intro-line">GNCE Onyx</span>
      </p>
    </div>

    <!-- Heat rail: fills with scroll like a gauge. Scroll-driven CSS;
         browsers without support simply never show it. -->
    <div class="heat-rail" aria-hidden="true"></div>

    <main id="main"><slot /></main>

    <Footer />
    <GearNav />

    <!-- The motion engine: GSAP + ScrollTrigger + Lenis, the pinned hero
         and roster, masked split-text, clip-wipe reveals, parallax, and
         magnetic pull. Bows out under reduced motion (static CSS stands in). -->
    <script>
      import '../scripts/motion';
    </script>

    <script>
      // Custom double-ring cursor. Fine pointers only; respects reduced motion.
      (() => {
        if (!matchMedia('(hover: hover) and (pointer: fine)').matches) return;
        if (matchMedia('(prefers-reduced-motion: reduce)').matches) return;
        const root = document.documentElement;
        const dot = document.querySelector('.cursor-dot');
        const ring = document.querySelector('.cursor-ring');
        if (!dot || !ring) return;
        root.classList.add('cursor-on');
        let mx = innerWidth / 2, my = innerHeight / 2, rx = mx, ry = my;
        addEventListener('pointermove', (e) => {
          mx = e.clientX; my = e.clientY;
          dot.style.transform = `translate(${mx}px, ${my}px) translate(-50%, -50%)`;
          const t = e.target;
          const hot = t && t.closest && t.closest('a, button, [data-magnetic], .btn, .gear-link, [role="button"]');
          ring.classList.toggle('is-hover', !!hot);
        }, { passive: true });
        const loop = () => {
          rx += (mx - rx) * 0.16; ry += (my - ry) * 0.16;
          ring.style.transform = `translate(${rx}px, ${ry}px) translate(-50%, -50%)`;
          requestAnimationFrame(loop);
        };
        requestAnimationFrame(loop);
        addEventListener('pointerdown', () => ring.classList.add('is-down'));
        addEventListener('pointerup', () => ring.classList.remove('is-down'));
      })();
    </script>

    <style>
      /* ---- Intro cover -------------------------------------------- */
      /* Sits offscreen by default; html.loading holds it down over the
         page, and removing the class lifts it into the hero entrance. */
      .intro {
        position: fixed;
        inset: 0;
        z-index: 120;
        display: flex;
        align-items: center;
        justify-content: center;
        background: var(--color-bg);
        transform: translateY(-101%);
        transition: transform 560ms var(--ease-in-out-strong);
        pointer-events: none;
      }

      :global(html.loading) .intro {
        transform: none;
        transition: none;
        pointer-events: auto;
      }

      :global(html.no-js) .intro {
        display: none;
      }

      .intro-mark {
        overflow: clip;
        font-size: clamp(2.5rem, 8vw, 5rem);
        color: var(--color-ink);
      }

      .intro-line {
        display: block;
        transform: translateY(115%);
      }

      :global(html.loading) .intro-line {
        animation: intro-strike 620ms var(--ease-out-strong) 120ms both;
      }

      @keyframes intro-strike {
        to {
          transform: translateY(0);
        }
      }

      /* ---- Heat rail ---------------------------------------------- */
      .heat-rail {
        display: none;
      }

      @supports (animation-timeline: scroll()) {
        .heat-rail {
          display: block;
          position: fixed;
          top: 0;
          left: 0;
          width: 3px;
          height: 100svh;
          z-index: 80;
          background: var(--color-accent);
          transform-origin: 0 0;
          transform: scaleY(0);
          animation: heat-fill linear both;
          animation-timeline: scroll(root);
          pointer-events: none;
        }

        @media (prefers-reduced-motion: reduce) {
          .heat-rail {
            display: none;
          }
        }
      }

      @keyframes heat-fill {
        from {
          transform: scaleY(0);
        }
        to {
          transform: scaleY(1);
        }
      }
    </style>

    <style is:global>
      /* ---- Cross-page continuity (View Transitions, progressive) --- */
      @view-transition {
        navigation: auto;
      }

      ::view-transition-old(root) {
        animation: vt-leave 200ms var(--ease-out-strong) both;
      }

      ::view-transition-new(root) {
        animation: vt-enter 320ms var(--ease-out-strong) both;
      }

      @keyframes vt-leave {
        to {
          opacity: 0;
        }
      }

      @keyframes vt-enter {
        from {
          opacity: 0;
          transform: translateY(12px);
        }
      }

      @media (prefers-reduced-motion: reduce) {
        ::view-transition-old(root),
        ::view-transition-new(root) {
          animation: none;
        }
      }
    </style>
  </body>
</html>
